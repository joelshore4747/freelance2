---
import { Github, Linkedin, Twitter, Mail } from "lucide-react"

const year = new Date().getFullYear()
---

<footer class="bg-card border-t border-border">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
      <div class="col-span-1 md:col-span-2">
        <div class="flex items-center space-x-2 mb-4">
          <div class="w-8 h-8 bg-primary rounded-lg flex items-center justify-center">
            <span class="text-primary-foreground font-bold text-lg font-sans">SD</span>
          </div>
          <span class="font-bold text-xl font-sans text-card-foreground">Studio Duo</span>
        </div>
        <p class="text-muted-foreground font-serif mb-4 max-w-md">
          A two-person freelance design and development studio creating modern, high-converting websites and digital
          experiences for forward-thinking businesses.
        </p>
        <div class="flex space-x-4">
          <a href="#" class="text-muted-foreground hover:text-primary transition-colors" aria-label="GitHub">
            <Github className="h-5 w-5" />
          </a>
          <a href="#" class="text-muted-foreground hover:text-primary transition-colors" aria-label="LinkedIn">
            <Linkedin className="h-5 w-5" />
          </a>
          <a href="#" class="text-muted-foreground hover:text-primary transition-colors" aria-label="Twitter">
            <Twitter className="h-5 w-5" />
          </a>
          <a href="#" class="text-muted-foreground hover:text-primary transition-colors" aria-label="Email">
            <Mail className="h-5 w-5" />
          </a>
        </div>
      </div>

      <div>
        <h3 class="font-semibold text-card-foreground font-sans mb-4">Quick Links</h3>
        <ul class="space-y-2">
          <li><a href="/about" class="text-muted-foreground hover:text-primary transition-colors font-serif">About Us</a></li>
          <li><a href="/services" class="text-muted-foreground hover:text-primary transition-colors font-serif">Services</a></li>
          <li><a href="/portfolio" class="text-muted-foreground hover:text-primary transition-colors font-serif">Portfolio</a></li>
          <li><a href="/contact" class="text-muted-foreground hover:text-primary transition-colors font-serif">Contact</a></li>
        </ul>
      </div>

      <div>
        <h3 class="font-semibold text-card-foreground font-sans mb-4">Services</h3>
        <ul class="space-y-2">
          <li><span class="text-muted-foreground font-serif">Web Design</span></li>
          <li><span class="text-muted-foreground font-serif">Development</span></li>
          <li><span class="text-muted-foreground font-serif">UI/UX Design</span></li>
          <li><span class="text-muted-foreground font-serif">Consulting</span></li>
        </ul>
      </div>
    </div>

    <div class="border-t border-border mt-8 pt-8 flex flex-col md:flex-row justify-between items-center">
      <p class="text-muted-foreground font-serif text-sm">© {year} Studio Duo. All rights reserved.</p>
      <div class="flex space-x-6 mt-4 md:mt-0">
        <a href="/privacy" class="text-muted-foreground hover:text-primary transition-colors font-serif text-sm">Privacy Policy</a>
        <a href="/terms" class="text-muted-foreground hover:text-primary transition-colors font-serif text-sm">Terms of Service</a>
      </div>
    </div>
  </div>
</footer>
