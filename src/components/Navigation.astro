---
import { ShoppingBag, CalendarCheck, Workflow, Sparkles, Search, ArrowRight, ChevronDown, Menu, X } from "lucide-react"

const servicesMenu = [
  { Icon: ShoppingBag,    title: "Ecommerce stores",    desc: "Shopify & WooCommerce builds that sell.",     href: "/services#ecommerce", tone: "" },
  { Icon: CalendarCheck,  title: "Booking websites",    desc: "Calendar-driven flows that customers finish.", href: "/services#booking",   tone: "v" },
  { Icon: Workflow,       title: "Workflow automation", desc: "n8n flows that quietly run the admin.",        href: "/automation",         tone: "m" },
  { Icon: Sparkles,       title: "AI business tools",   desc: "Practical assistants for support & ops.",      href: "/services#ai",        tone: "p" },
  { Icon: Search,         title: "SEO & growth",        desc: "Earn search traffic instead of paying for it.", href: "/services#seo",      tone: "v" },
]

const workMenu = [
  { title: "All projects",          href: "/work" },
  { title: "Ecommerce",             href: "/work#ecommerce" },
  { title: "Booking",               href: "/work#booking" },
  { title: "Automation case study", href: "/automation" },
]
---

<div class="sd-topbar">
  <div class="sd-wrap sd-topbar-row">
    <span class="sd-badge">New</span>
    <span>Now booking Q3 2026 — limited to 4 new clients.</span>
    <a href="/contact">
      Get in touch
      <svg class="sd-ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:14px;height:14px"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
    </a>
  </div>
</div>

<header class="sd-nav">
  <div class="sd-wrap sd-nav-row">
    <a class="sd-logo" href="/">
      <span class="sd-logo-mark"></span>
      <span>Studio&nbsp;Duo</span>
    </a>

    <nav class="sd-nav-center" aria-label="Primary">
      <div class="sd-nav-item has-menu">
        <button class="sd-nav-link" type="button" aria-haspopup="true">
          Services
          <ChevronDown className="sd-caret" />
        </button>
        <div class="sd-menu" role="menu">
          <div class="sd-menu-grid">
            {servicesMenu.map(item => (
              <a class="sd-menu-item" href={item.href} role="menuitem">
                <span class={`sd-menu-icon ${item.tone}`}><item.Icon className="sd-ic" /></span>
                <div>
                  <div class="sd-menu-title">{item.title}</div>
                  <div class="sd-menu-desc">{item.desc}</div>
                </div>
              </a>
            ))}
          </div>
          <div class="sd-menu-foot">
            <div>
              <div class="ft">Not sure where to start?</div>
              <div class="fs">Book a 20-min intro call — free, no pitch.</div>
            </div>
            <a href="/contact">
              Book a call
              <svg class="sd-ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:14px;height:14px"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
            </a>
          </div>
        </div>
      </div>

      <div class="sd-nav-item has-menu">
        <button class="sd-nav-link" type="button" aria-haspopup="true">
          Work
          <ChevronDown className="sd-caret" />
        </button>
        <div class="sd-menu small" role="menu">
          <div class="sd-menu-grid">
            {workMenu.map(item => (
              <a class="sd-menu-item" href={item.href} role="menuitem">
                <span class="sd-menu-icon">→</span>
                <div><div class="sd-menu-title">{item.title}</div></div>
              </a>
            ))}
          </div>
        </div>
      </div>

      <a class="sd-nav-link" href="/pricing">Pricing</a>
      <a class="sd-nav-link" href="/about">About</a>
      <a class="sd-nav-link" href="/contact">Contact</a>
    </nav>

    <div class="sd-nav-right">
      <button
        data-theme-toggle
        type="button"
        class="sd-theme-toggle"
        aria-label="Toggle theme"
      >
        <span data-theme-icon>🌙</span>
      </button>
      <a class="sd-btn-sm-primary" href="/contact">
        Start a project
        <svg class="sd-ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" style="width:14px;height:14px"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
      </a>
      <button
        data-mobile-toggle
        type="button"
        class="sd-mobile-toggle"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        <span data-mobile-icon="menu"><Menu className="sd-ic" /></span>
        <span data-mobile-icon="close" class="hidden"><X className="sd-ic" /></span>
      </button>
    </div>
  </div>

  <div data-mobile-panel class="sd-mobile-panel">
    <div class="sd-wrap">
      <div class="sd-mobile-group">
        <div class="sd-mobile-group-title">Services</div>
        {servicesMenu.map(item => (
          <a class="sd-mobile-link" href={item.href}>{item.title}<svg class="sd-ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 6l6 6-6 6"/></svg></a>
        ))}
      </div>
      <div class="sd-mobile-group">
        <div class="sd-mobile-group-title">Work</div>
        {workMenu.map(item => (
          <a class="sd-mobile-link" href={item.href}>{item.title}<svg class="sd-ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 6l6 6-6 6"/></svg></a>
        ))}
      </div>
      <div class="sd-mobile-group">
        <div class="sd-mobile-group-title">More</div>
        <a class="sd-mobile-link" href="/pricing">Pricing<svg class="sd-ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 6l6 6-6 6"/></svg></a>
        <a class="sd-mobile-link" href="/about">About<svg class="sd-ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 6l6 6-6 6"/></svg></a>
        <a class="sd-mobile-link" href="/contact">Contact<svg class="sd-ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 6l6 6-6 6"/></svg></a>
      </div>
    </div>
  </div>
</header>

<script>
  const root = document.documentElement
  const savedTheme = localStorage.getItem("theme")
  const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches
  const initialDark = savedTheme === "dark" || (!savedTheme && prefersDark)
  root.classList.toggle("dark", initialDark)

  const syncThemeIcons = () => {
    const dark = root.classList.contains("dark")
    document.querySelectorAll<HTMLElement>("[data-theme-icon]").forEach(el => {
      el.textContent = dark ? "☀️" : "🌙"
    })
  }
  syncThemeIcons()

  document.querySelectorAll<HTMLButtonElement>("[data-theme-toggle]").forEach(btn => {
    btn.addEventListener("click", () => {
      const next = !root.classList.contains("dark")
      root.classList.toggle("dark", next)
      localStorage.setItem("theme", next ? "dark" : "light")
      syncThemeIcons()
    })
  })

  const mobileToggle = document.querySelector<HTMLButtonElement>("[data-mobile-toggle]")
  const mobilePanel = document.querySelector<HTMLElement>("[data-mobile-panel]")
  const iconMenu = document.querySelector<HTMLElement>('[data-mobile-icon="menu"]')
  const iconClose = document.querySelector<HTMLElement>('[data-mobile-icon="close"]')

  const setMobileOpen = (open: boolean) => {
    if (!mobileToggle || !mobilePanel || !iconMenu || !iconClose) return
    mobileToggle.setAttribute("aria-expanded", String(open))
    mobilePanel.classList.toggle("open", open)
    iconMenu.classList.toggle("hidden", open)
    iconClose.classList.toggle("hidden", !open)
  }

  mobileToggle?.addEventListener("click", () => {
    setMobileOpen(mobileToggle.getAttribute("aria-expanded") !== "true")
  })

  mobilePanel?.querySelectorAll("a").forEach(a => a.addEventListener("click", () => setMobileOpen(false)))

  document.querySelectorAll<HTMLElement>(".sd-nav-item.has-menu").forEach(item => {
    const trigger = item.querySelector<HTMLButtonElement>(".sd-nav-link")
    trigger?.addEventListener("keydown", (e) => {
      if (e.key === "Escape") (document.activeElement as HTMLElement | null)?.blur()
    })
  })
</script>
