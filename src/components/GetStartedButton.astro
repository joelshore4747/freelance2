---
import { ArrowRight } from "lucide-react"

type Props = {
  variant?: "default" | "outline" | "sticky"
  size?: "default" | "lg" | "sm"
  class?: string
}

const { variant = "default", size = "default", class: extra = "" } = Astro.props

const sizeClass = size === "lg" ? "h-10 px-6 text-base" : size === "sm" ? "h-8 px-3 text-sm" : "h-9 px-4 text-sm"
const variantClass =
  variant === "outline"
    ? "border bg-background hover:bg-accent hover:text-accent-foreground"
    : "bg-slate-800 hover:bg-slate-700 text-white"
---

{
  variant === "sticky" ? (
    <div class="fixed bottom-6 right-6 z-50">
      <a
        href="/contact"
        class={`group inline-flex items-center justify-center gap-2 rounded-md font-medium shadow-lg hover:shadow-xl transition-all duration-300 h-10 px-6 text-base bg-slate-800 hover:bg-slate-700 text-white ${extra}`}
      >
        Get Started
        <ArrowRight className="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" />
      </a>
    </div>
  ) : (
    <a
      href="/contact"
      class={`group inline-flex items-center justify-center gap-2 rounded-md font-medium shadow-lg hover:shadow-xl transition-all duration-300 ${sizeClass} ${variantClass} ${extra}`}
    >
      Get Started
      <ArrowRight className="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" />
    </a>
  )
}
