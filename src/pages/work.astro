---
import Layout from "@/layouts/Layout.astro"
import Navigation from "@/components/Navigation.astro"
import Footer from "@/components/Footer.astro"

type Work = {
  id: number
  title: string
  company: string
  category: string
  desc: string
  tags: string[]
  media: string
  mark: string
  feature?: boolean
  image?: string
  live?: string
}

const works: Work[] = [
  { id: 1,  title: "Estate site for a heritage golf club", company: "Lyndhurst Park",       category: "Ecommerce",
    desc: "A full-bleed brochure site for the estate — course, clubhouse, membership, society days — built to feel hand-set.",
    tags: ["Landing","Editorial","Responsive"],          media: "olive", feature: true, mark: "Lyndhurst",
    image: "/portfolio/assets/01-hero-course-at-first-light.png", live: "/portfolio/lyndhurst-park.html" },
  { id: 2,  title: "Tee-time booking, member-aware",     company: "Lyndhurst Park",        category: "Booking",
    desc: "Packages, member rates, deposits and a calm summary panel — the booking flow that runs the day.",
    tags: ["Booking","Stripe","Calendar"],               media: "olive", mark: "Tee-time",
    image: "/portfolio/website_snippet_images/golfbooking.png", live: "/portfolio/book-a-tee-time.html" },
  { id: 3,  title: "Class booking that fills the mats",  company: "Hollowford Yoga",       category: "Booking",
    desc: "Schedule, capacity, member passes and the reminder cadence — class booking with a quiet, considered feel.",
    tags: ["Booking","Memberships","SMS"],               media: "stone", mark: "Hollowford",
    image: "/portfolio/yoga_assets/yoga1.jpeg", live: "/portfolio/yoga-booking.html" },
  { id: 4,  title: "Subscription store, doubled",        company: "Roma Supplements",     category: "Ecommerce",
    desc: "Subscribe-and-save flow with bundle discounts, account portal and churn-saver emails.",
    tags: ["Shopify","Subscriptions","Klaviyo"],         media: "peach", mark: "Roma" },
  { id: 5,  title: "Bookings paid in the first weekend", company: "Bloom Hair & Beauty",   category: "Booking",
    desc: "Salon booking with deposits, reminders and a stylist-by-stylist flow.",
    tags: ["Booking","Stripe","SMS"],                    media: "stone", mark: "Bloom" },
  { id: 6,  title: "An n8n flow that runs admin",        company: "Ledger & Co",           category: "Automation",
    desc: "Enquiry → enrichment → AI summary → CRM, with a Slack alert at every step.",
    tags: ["n8n","AI","HubSpot"],                        media: "dark",  mark: "Ledger" },
  { id: 7,  title: "Support chatbot that answers 70%",   company: "Stille Skincare",       category: "AI",
    desc: "Trained on FAQs, product docs and order history. Honest 'I don't know' mode included.",
    tags: ["OpenAI","Zendesk","Shopify"],                media: "copper",mark: "Stille" },
  { id: 8,  title: "Northline editorial relaunch",       company: "Northline Studio",      category: "Ecommerce",
    desc: "Headless storefront with editorial cadence — sections feel hand-set, but they're CMS-driven.",
    tags: ["Shopify","Sanity","Tailwind"],               media: "stone", mark: "Northline" },
  { id: 9,  title: "Enquiry triage with AI summaries",   company: "Northwind Studio",      category: "Automation",
    desc: "Form → enriched → AI summary → assigned to the right partner. 3-minute response promise.",
    tags: ["n8n","OpenAI","Slack"],                      media: "dark",  mark: "Triage" },
  { id: 10, title: "Outbound copilot for SDRs",          company: "Reach (internal tool)", category: "AI",
    desc: "Human-in-the-loop assistant with hard guardrails and a complete audit trail.",
    tags: ["Python","FastAPI","LLM"],                    media: "copper",mark: "Reach" },
  { id: 11, title: "Maple onboarding rebuilt",           company: "Maple",                  category: "Ecommerce",
    desc: "From cold visitor to verified account in under three minutes — measured across 8,000 sessions.",
    tags: ["TypeScript","Stripe","Plaid"],               media: "peach", mark: "Maple" },
  { id: 12, title: "Clinic intake & reminders",          company: "Atlas Health",           category: "Booking",
    desc: "Frictionless intake form, calmer scheduling flow, measurable drop-off reductions.",
    tags: ["Booking","HIPAA-style","SMS"],               media: "",      mark: "Atlas" },
  { id: 13, title: "Product description generator",      company: "Field & Foundry",        category: "AI",
    desc: "Brand-trained generator that drafts product copy in three voices, with editor approval.",
    tags: ["OpenAI","Notion","Shopify"],                 media: "olive", mark: "F&F" },
]

const cats = ["All", "Ecommerce", "Booking", "Automation", "AI"]
---

<Layout
  title="Work — Studio Duo"
  description="A selection of recent builds across ecommerce, booking, automation and AI."
>
  <Navigation />

  <section class="page-head">
    <div class="wrap">
      <div class="crumb">
        <a href="/">Studio Duo</a>
        <span class="sep">/</span>
        <span>Work</span>
      </div>
      <div class="page-head-grid">
        <div data-reveal>
          <span class="eyebrow">Selected work</span>
          <h1>A small portfolio of <em>real builds.</em></h1>
          <p class="lede">Every project below is a live build. Most are still running. Filter by service or browse the lot — case studies open with the brief, the problem, the build and the numbers.</p>
        </div>
        <div class="page-head-meta" data-reveal>
          <div><div class="k">Total shipped</div><div class="v">150+ projects</div></div>
          <div><div class="k">Retention</div><div class="v">98%</div></div>
          <div><div class="k">Industries</div><div class="v">Retail, wellness, B2B</div></div>
          <div><div class="k">Years active</div><div class="v">Since 2021</div></div>
        </div>
      </div>
    </div>
  </section>

  <section class="section work-section">
    <div class="wrap">
      <div class="work-toolbar">
        <div class="pills" id="work-pills">
          {cats.map((c, i) => (
            <button class={`pill ${i === 0 ? "active" : ""}`} data-cat={c} type="button">{c === "AI" ? "AI tools" : c}</button>
          ))}
        </div>
        <div class="work-count"><span id="work-count">{works.length}</span> projects · 2024 — 2026</div>
      </div>
    </div>

    <div class="rail-head wrap">
      <div data-reveal>
        <span class="eyebrow">Browse the rail</span>
        <h2 class="sec-title left">Recent projects, <em>swipe through.</em></h2>
      </div>
      <div class="rail-arrows">
        <button class="arrow-btn" id="work-prev" type="button" aria-label="Previous"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 18l-6-6 6-6"/></svg></button>
        <button class="arrow-btn" id="work-next" type="button" aria-label="Next"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg></button>
      </div>
    </div>

    <div class="dv2-rail work-rail" id="work-rail" role="region" aria-roledescription="carousel" aria-label="Work projects">
      <div class="lead" aria-hidden="true"></div>
      {works.map((w, i) => (
        <a
          class={`wcard ${w.feature ? "feature" : ""} ${w.live ? "has-shot" : ""}`}
          href={w.live ?? "/case-study"}
          data-preview={w.live ?? undefined}
          data-preview-title={w.live ? `${w.company} — ${w.title}` : undefined}
          data-card
          data-cat={w.category}
        >
          <div class={`media ${w.media}`}>
            {w.image && <img src={w.image} alt={`${w.company} — ${w.title}`} loading="lazy" />}
            <span class="tag-top">{w.category}</span>
            <span class="num-corner">{String(i + 1).padStart(2, "0")} / {String(works.length).padStart(2, "0")}</span>
            {!w.image && <div class="mark">{w.mark}</div>}
            {w.live && <span class="live-dot" aria-hidden="true">Live</span>}
          </div>
          <div class="body">
            <div class="meta"><span>{w.company}</span><span>2026</span></div>
            <h3>{w.title}</h3>
            <p>{w.desc}</p>
          </div>
          <div class="foot">
            <div class="tags">
              {w.tags.map(t => <span class="t">{t}</span>)}
            </div>
            <span class="link-arrow">{w.live ? "Preview build" : "Case study"}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
            </span>
          </div>
        </a>
      ))}
      <div class="tail" aria-hidden="true"></div>
    </div>

    <div class="wrap">
      <div class="rail-controls">
        <span class="counter" id="work-counter">01 / {String(works.length).padStart(2, "0")}</span>
        <div class="progress" id="work-progress"></div>
        <a class="link-arrow" href="/contact" style="font-size:13px">Ask for the full list →</a>
      </div>
    </div>

    <div class="wrap" style="margin-top:90px">
      <div class="sec-head left" data-reveal style="margin-bottom:32px">
        <span class="eyebrow">Or browse the grid</span>
        <h2 class="sec-title">The whole <em>portfolio.</em></h2>
      </div>
      <div class="grid-work" id="work-grid">
        {works.map(w => (
          <a
            class={`wcard ${w.feature ? "feature" : ""} ${w.live ? "has-shot" : ""}`}
            href={w.live ?? "/case-study"}
            data-preview={w.live ?? undefined}
            data-preview-title={w.live ? `${w.company} — ${w.title}` : undefined}
            data-grid-card
            data-cat={w.category}
          >
            <div class={`media ${w.media}`}>
              {w.image && <img src={w.image} alt={`${w.company} — ${w.title}`} loading="lazy" />}
              <span class="tag-top">{w.category}</span>
              {!w.image && <div class="mark">{w.mark}</div>}
              {w.live && <span class="live-dot" aria-hidden="true">Live</span>}
            </div>
            <div class="body">
              <div class="meta"><span>{w.company}</span><span>2026</span></div>
              <h3>{w.title}</h3>
              <p>{w.desc}</p>
            </div>
            <div class="foot">
              <div class="tags">
                {w.tags.map(t => <span class="t">{t}</span>)}
              </div>
              <span class="link-arrow">Case study
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </span>
            </div>
          </a>
        ))}
      </div>

      <div class="work-empty" id="work-empty" hidden>
        <p>Nothing in this category yet — but we've probably built something close.</p>
        <a class="btn btn-ghost" href="/contact">Ask for the full list</a>
      </div>

      <div style="margin-top:48px;text-align:center">
        <span class="work-count" style="display:block;margin-bottom:14px">That's the public selection.</span>
        <a class="btn btn-ghost" href="/contact">Ask for the full list (under NDA)
          <svg class="ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <section class="section" style="background:var(--bg-2);border-top:1px solid var(--hair);border-bottom:1px solid var(--hair);padding:80px 0">
    <div class="wrap">
      <div class="sec-head left" data-reveal style="margin-bottom:32px">
        <span class="eyebrow">By the numbers</span>
        <h2 class="sec-title">Outcomes across <em>the portfolio.</em></h2>
      </div>
      <div class="stats-strip">
        <div class="cell"><div class="v">+34<em>%</em></div><div class="l">Avg conversion lift</div></div>
        <div class="cell"><div class="v">−42<em>%</em></div><div class="l">Avg drop-off reduction</div></div>
        <div class="cell"><div class="v">68<em>%</em></div><div class="l">Enquiries auto-handled</div></div>
        <div class="cell"><div class="v">98<em>%</em></div><div class="l">Client retention</div></div>
      </div>
    </div>
  </section>

  <section class="cta">
    <div class="cta-inner">
      <span class="eyebrow">Start a project</span>
      <h2>Yours next, <em>maybe?</em></h2>
      <p>Tell us what you want to ship — we'll come back with a plan and a price inside 24 hours.</p>
      <div class="cta-actions">
        <a class="btn btn-primary" href="/contact">
          Start a project
          <svg class="ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </a>
        <a class="btn btn-ghost" href="/services">Browse services</a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<style is:global>
  .work-section { padding: 64px 0 110px; }
  .work-toolbar { display: flex; gap: 16px; flex-wrap: wrap; align-items: center; justify-content: space-between; margin: 0 0 40px; }
  .work-count { font-family: "Fragment Mono", monospace; font-size: 12px; color: var(--muted-dim); letter-spacing: .12em; text-transform: uppercase; }
  .work-count b { color: var(--ink); font-weight: 500; }

  .rail-head { display: flex; justify-content: space-between; align-items: end; gap: 24px; flex-wrap: wrap; margin: 12px auto 30px; }
  .rail-arrows { display: flex; gap: 10px; align-items: center; }
  .sec-title.left { text-align: left; max-width: 18ch; }

  /* Carousel rail card sizing --------------------------------- */
  .work-rail .wcard { width: min(420px, 84vw); flex: 0 0 auto; scroll-snap-align: start; scroll-snap-stop: always; }

  /* Grid view ------------------------------------------------- */
  .grid-work { display: grid; gap: 18px; grid-template-columns: 1fr; }
  @media (min-width: 720px)  { .grid-work { grid-template-columns: 1fr 1fr; } }
  @media (min-width: 1100px) { .grid-work { grid-template-columns: 1fr 1fr 1fr; } }

  .grid-work .wcard.feature { grid-column: span 1; }
  @media (min-width: 1100px) { .grid-work .wcard.feature { grid-column: span 2; } }

  /* Cards (shared by rail + grid) ----------------------------- */
  .wcard {
    background: var(--surface); border: 1px solid var(--hair); border-radius: var(--r-lg);
    overflow: hidden; display: grid; grid-template-rows: auto 1fr auto;
    transition: transform .35s cubic-bezier(.32,.72,0,1), box-shadow .35s cubic-bezier(.32,.72,0,1);
    text-decoration: none; color: inherit;
  }
  .wcard:hover { transform: translateY(-4px); box-shadow: var(--shadow-md); }
  .wcard .media { position: relative; aspect-ratio: 16/9; overflow: hidden; background: linear-gradient(135deg, #F7F3EA 0%, #EBD9CC 100%); }
  .wcard .media.stone  { background: linear-gradient(135deg, #F7F3EA 0%, #E7DED2 100%); }
  .wcard .media.peach  { background: linear-gradient(135deg, #FFF9EF 0%, #EBD6C8 100%); }
  .wcard .media.dark   { background: linear-gradient(135deg, #1A1815 0%, #2F2A24 100%); }
  .wcard .media.copper { background: linear-gradient(135deg, var(--brand), #6B3B2E); }
  .wcard .media.olive  { background: linear-gradient(135deg, #BFAE8F, #6E6845); }
  .wcard .media::before {
    content: ""; position: absolute; inset: 0;
    background:
      radial-gradient(60% 80% at 80% 20%, color-mix(in oklab, var(--brand) 30%, transparent), transparent 70%),
      radial-gradient(60% 80% at 20% 80%, color-mix(in oklab, var(--brand-2) 25%, transparent), transparent 70%);
  }
  .wcard .media .tag-top {
    position: absolute; top: 14px; left: 14px; z-index: 2;
    padding: 6px 10px; border-radius: 8px; background: var(--surface); color: var(--ink);
    font-family: "Fragment Mono", monospace; font-size: 11px; text-transform: uppercase; letter-spacing: .1em;
    border: 1px solid var(--hair); box-shadow: var(--shadow-sm);
  }
  .wcard .media .num-corner {
    position: absolute; bottom: 14px; right: 14px; z-index: 2;
    font-family: "Fragment Mono", monospace; font-size: 11px; color: var(--ink);
    padding: 4px 8px; border-radius: 6px;
    background: color-mix(in oklab, var(--surface) 80%, transparent); backdrop-filter: blur(8px);
  }
  .wcard .media .mark {
    position: absolute; inset: 0; display: grid; place-items: center;
    font-family: "Gloock", serif; font-size: 64px; letter-spacing: -.04em;
    color: var(--ink); opacity: .14; z-index: 1; pointer-events: none;
    text-align: center; padding: 0 32px; font-weight: 400;
  }
  .wcard .media.dark .mark,
  .wcard .media.copper .mark,
  .wcard .media.olive .mark { color: var(--surface); opacity: .25; }

  /* Real-build card variant — full-bleed screenshot + live dot */
  .wcard .media img {
    position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; z-index: 0;
    transition: transform .6s cubic-bezier(.32,.72,0,1);
  }
  .wcard.has-shot:hover .media img { transform: scale(1.03); }
  .wcard.has-shot .media::before {
    background:
      linear-gradient(180deg, rgba(0,0,0,0) 55%, rgba(0,0,0,.45) 100%),
      radial-gradient(60% 80% at 80% 20%, color-mix(in oklab, var(--brand) 14%, transparent), transparent 70%);
  }
  .wcard.has-shot .media .tag-top,
  .wcard.has-shot .media .num-corner,
  .wcard.has-shot .media .live-dot { z-index: 2; }
  .wcard .media .live-dot {
    position: absolute; top: 14px; right: 14px; z-index: 2;
    display: inline-flex; align-items: center; gap: 6px;
    padding: 6px 10px; border-radius: 999px;
    background: color-mix(in oklab, #0E1410 70%, transparent); color: #F6F2E8;
    font-family: "Fragment Mono", monospace; font-size: 10px; text-transform: uppercase; letter-spacing: .14em;
    backdrop-filter: blur(6px);
  }
  .wcard .media .live-dot::before {
    content: ""; width: 6px; height: 6px; border-radius: 50%;
    background: #7CD08F; box-shadow: 0 0 0 3px color-mix(in oklab, #7CD08F 35%, transparent);
  }

  .wcard .body { padding: 22px 24px 16px; display: grid; gap: 10px; }
  .wcard .body .meta { display: flex; justify-content: space-between; align-items: center; font-family: "Fragment Mono", monospace; font-size: 11px; color: var(--muted-dim); text-transform: uppercase; letter-spacing: .14em; }
  .wcard .body h3 { font-family: "Gloock", serif; font-weight: 400; font-size: 24px; line-height: 1.04; margin: 0; letter-spacing: -.03em; }
  .wcard .body p { color: var(--muted-ink); margin: 0; font-size: 14.5px; line-height: 1.55; }
  .wcard .foot { display: flex; justify-content: space-between; align-items: center; padding: 14px 24px 18px; border-top: 1px solid var(--hair-2); }
  .wcard .foot .tags { display: flex; gap: 6px; flex-wrap: wrap; }
  .wcard .foot .t { font-family: "Fragment Mono", monospace; font-size: 11px; padding: 4px 8px; border: 1px solid var(--hair); border-radius: 6px; color: var(--muted-ink); }

  /* Empty filter state ---------------------------------------- */
  .work-empty { text-align: center; padding: 60px 24px; }
  .work-empty p { color: var(--muted-ink); margin: 0 0 20px; }

  /* Stats strip ----------------------------------------------- */
  .stats-strip { display: grid; grid-template-columns: repeat(2,1fr); gap: 0; border: 1px solid var(--hair); border-radius: 16px; overflow: hidden; background: var(--surface); }
  @media (min-width: 800px) { .stats-strip { grid-template-columns: repeat(4,1fr); } }
  .stats-strip .cell { padding: 28px 20px; text-align: center; border-right: 1px solid var(--hair); }
  .stats-strip .cell:last-child { border-right: 0; }
  .stats-strip .v { font-family: "Gloock", serif; font-size: 38px; letter-spacing: -.04em; line-height: 1; font-weight: 400; }
  .stats-strip .v em { font-style: normal; background: linear-gradient(135deg, var(--brand), var(--brand-2)); -webkit-background-clip: text; background-clip: text; color: transparent; }
  .stats-strip .l { margin-top: 8px; font-size: 12px; color: var(--muted-ink); font-family: "Fragment Mono", monospace; letter-spacing: .12em; text-transform: uppercase; }
</style>

<script>
  import { measureRail, railStep, railSettleIdx } from "@/lib/carouselRail"

  /* ===== Filter pills ===== */
  const pillsBox = document.getElementById("work-pills")
  const grid = document.getElementById("work-grid")
  const countEl = document.getElementById("work-count")
  const empty = document.getElementById("work-empty")
  const gridCards = grid ? Array.from(grid.querySelectorAll<HTMLElement>("[data-grid-card]")) : []

  const applyFilter = (cat: string) => {
    if (!grid || !countEl || !empty) return
    pillsBox?.querySelectorAll("button").forEach(b => b.classList.toggle("active", b.dataset.cat === cat))
    let shown = 0
    for (const card of gridCards) {
      const match = cat === "All" || card.dataset.cat === cat
      card.style.display = match ? "" : "none"
      if (match) shown += 1
    }
    countEl.textContent = String(shown)
    empty.toggleAttribute("hidden", shown > 0)
  }

  pillsBox?.addEventListener("click", (e) => {
    const b = (e.target as HTMLElement).closest<HTMLButtonElement>("button")
    if (b?.dataset.cat) applyFilter(b.dataset.cat)
  })

  const params = new URLSearchParams(window.location.search)
  const initialCat = params.get("cat") || "All"
  applyFilter(initialCat)

  /* ===== Smooth-carousel rail ===== */
  const pad = (n: number) => String(n).padStart(2, "0")
  const rail = document.getElementById("work-rail") as HTMLElement | null
  const prev = document.getElementById("work-prev") as HTMLButtonElement | null
  const next = document.getElementById("work-next") as HTMLButtonElement | null
  const counter = document.getElementById("work-counter")
  const progress = document.getElementById("work-progress")

  if (rail && prev && next && counter && progress) {
    const refresh = () => {
      const s = measureRail(rail)
      prev.disabled = !s.canPrev
      next.disabled = !s.canNext
      counter.textContent = `${pad(s.index + 1)} / ${pad(s.total)}`
      const pct = s.total > 1 ? (s.index / (s.total - 1)) * 100 : 0
      progress.style.setProperty("--p", `${pct}%`)
    }
    prev.addEventListener("click", () => { railStep(rail, -1); refresh() })
    next.addEventListener("click", () => { railStep(rail, 1); refresh() })
    let settle: number | undefined
    rail.addEventListener("scroll", () => {
      if (rail.__animId != null) return
      if (settle) window.clearTimeout(settle)
      settle = window.setTimeout(() => {
        if (rail.__animId == null) railSettleIdx(rail)
        refresh()
      }, 140)
    }, { passive: true })
    rail.tabIndex = 0
    rail.addEventListener("keydown", (e: KeyboardEvent) => {
      if (e.key === "ArrowLeft") { e.preventDefault(); railStep(rail, -1); refresh() }
      else if (e.key === "ArrowRight") { e.preventDefault(); railStep(rail, 1); refresh() }
    })
    new ResizeObserver(refresh).observe(rail)
    refresh()
  }
</script>
