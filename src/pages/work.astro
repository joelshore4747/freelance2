---
import { ArrowRight, CheckCircle2, Code2, Film, Handshake, Layers, Orbit, PenTool, Play, Rocket, Search, ShoppingBag, Sparkles, TrendingUp } from "lucide-react"
import Layout from "@/layouts/Layout.astro"
import Navigation from "@/components/Navigation.astro"
import Footer from "@/components/Footer.astro"
import Badge from "@/components/ui/Badge.astro"
import { SpotlightCarousel } from "@/components/SpotlightCarousel"
import { ShowcaseCarousel } from "@/components/ShowcaseCarousel"
import { CornerVideoPlayer } from "@/components/CornerVideoPlayer"

const heroStats = [
  { label: "Bookings handled", value: "120k+", Icon: Rocket, tone: "bg-primary/10 text-primary" },
  { label: "Ecommerce builds shipped", value: "60+", Icon: ShoppingBag, tone: "bg-standout/10 text-standout" },
  { label: "Hours saved per month", value: "1.4k", Icon: TrendingUp, tone: "bg-accent/10 text-accent" },
  { label: "Automations running", value: "200+", Icon: Handshake, tone: "bg-standout-2-10 text-standout-2" },
]

const showreelHighlights = [
  { title: "Booking pages that convert", description: "Clean flows for golf, yoga, spa, gym and restaurant reservations — designed to remove the back-and-forth.", Icon: Layers, tone: "bg-primary/10 text-primary" },
  { title: "Ecommerce that sells", description: "Premium product pages, trust signals, frictionless checkout, and email capture wired in from day one.", Icon: ShoppingBag, tone: "bg-standout/10 text-standout" },
  { title: "Automation that pays back", description: "n8n flows that remove copy-paste admin and chase leads while you sleep.", Icon: Orbit, tone: "bg-accent/10 text-accent" },
  { title: "AI where it earns its keep", description: "Chatbots, summaries, drafts and qualification — scoped, not sprayed across every page.", Icon: Handshake, tone: "bg-standout-2-10 text-standout-2" },
]

const spotlightProjects = [
  { id: "golf-booking", category: "Booking", title: "Golf tee-time booking", description: "Member rates, weather-aware availability, deposit-on-book and instant confirmations. Includes a clean admin view for the pro shop.", image: "/saas-dashboard-analytics-interface.jpg", video: "/videos/atlas.mp4", outcomes: ["Tee-time bookings up 3.2×", "Phone enquiries down 70%", "Deposits captured at the point of booking"], link: "/contact?project=golf-booking" },
  { id: "beauty-store", category: "Ecommerce", title: "Hair & beauty product store", description: "Premium product storytelling, reviews, subscription flow, and a fast one-page checkout on Shopify.", image: "/modern-ecommerce-interface.png", video: "/videos/lumos.mp4", outcomes: ["4.1% visitor-to-purchase", "Subscriptions on 28% of orders", "Repeat purchase rate up 35%"], link: "/contact?project=beauty-store" },
  { id: "enquiry-automation", category: "Automation", title: "Enquiry → CRM automation", description: "Every form submission enriched, summarised by AI, scored, and pushed to the right person on Slack within 60 seconds.", image: "/mobile-fitness-app-interface-design.jpg", video: "/videos/pulse.mp4", outcomes: ["Lead response time: 47s avg", "Manual data entry eliminated", "Pipeline visibility per-channel"], link: "/contact?project=enquiry-automation" },
]

const projects = [
  { id: "yoga-booking", title: "Yoga studio class booking", category: "Booking", summary: "Class schedule with capacity, waitlists, member passes, drop-in payments and email reminders.", image: "/mobile-fitness-app-interface-design.jpg", metrics: [{ label: "No-shows", value: "-40%" }, { label: "Class fill rate", value: "92%" }, { label: "Pass renewals", value: "+22%" }], stack: ["Astro", "Stripe", "Calendly", "n8n"] },
  { id: "fashion-store", title: "Fashion brand storefront", category: "Ecommerce", summary: "Clean collection navigation, lookbook product pages, reviews, email capture, and a one-page checkout.", image: "/placeholder-95zgk.png", metrics: [{ label: "Conversion rate", value: "3.8%" }, { label: "AOV", value: "+18%" }, { label: "Launch", value: "5 weeks" }], stack: ["Shopify", "Klaviyo", "Tailwind", "Analytics"] },
  { id: "spa-booking", title: "Spa treatment booking", category: "Booking", summary: "Treatment picker with stylist preferences, deposits, gift cards, and SMS reminders the morning of.", image: "/placeholder-ks40r.png", metrics: [{ label: "Bookings online", value: "78%" }, { label: "Phone calls", value: "-60%" }, { label: "Gift cards", value: "+£18k/mo" }], stack: ["Astro", "Stripe", "Twilio", "Sheets"] },
  { id: "order-automation", title: "Ecommerce order automation", category: "Automation", summary: "Order placed → fulfilment alert → label printed → branded receipt → review request 7 days later. All visible in n8n.", image: "/placeholder-49g40.png", metrics: [{ label: "Order handling", value: "Fully auto" }, { label: "Review requests", value: "100%" }, { label: "Manual steps", value: "0" }], stack: ["Shopify", "n8n", "ShipStation", "Klaviyo"] },
  { id: "fitness-supplements", title: "Fitness supplement store", category: "Ecommerce", summary: "Bundle builder, subscription flow, ingredient transparency, and trust signals tuned for repeat purchase.", image: "/placeholder-7fi4h.png", metrics: [{ label: "Subscription rate", value: "31%" }, { label: "AOV", value: "+24%" }, { label: "Returning", value: "44%" }], stack: ["Shopify", "Recharge", "Klaviyo", "PostgreSQL"] },
  { id: "ai-support", title: "AI customer support assistant", category: "AI", summary: "Chatbot trained on FAQs, products, returns policy and order data. Hands off to a human with full context when needed.", image: "/data-analytics-dashboard.png", metrics: [{ label: "Auto-resolved", value: "62%" }, { label: "First reply", value: "Instant" }, { label: "CSAT", value: "4.7/5" }], stack: ["OpenAI", "Pinecone", "n8n", "Zendesk"] },
]

const categories = ["All", "Booking", "Ecommerce", "Automation", "AI"]

const focusAreas = [
  { title: "Booking websites", description: "Clean booking flows for service businesses that want customers to book without calling.", Icon: Layers, tone: "bg-primary/10 text-primary", points: ["Appointment / class / reservation flows", "Deposit & gift-card payment setup", "Calendar + email/SMS confirmations"] },
  { title: "Ecommerce stores", description: "Shopify and WooCommerce builds tuned for trust, clarity and checkout speed.", Icon: ShoppingBag, tone: "bg-standout/10 text-standout", points: ["Product, collection and cart polish", "Reviews, trust and email capture", "Subscriptions, bundles, lifecycle emails"] },
  { title: "Automation + AI", description: "n8n workflows and practical AI tools that remove repetitive admin and chase leads.", Icon: Sparkles, tone: "bg-accent/10 text-accent", points: ["Form → CRM → Slack alerts", "AI chatbots and enquiry summaries", "Order, booking and email automations"] },
]

const processSteps = [
  { title: "Plan", description: "Understand the offer, current tools and the workflows you want to fix or build.", detail: "Audit + scope + success metrics", Icon: Search, tone: "bg-primary/10 text-primary" },
  { title: "Design", description: "Clear pages, simple flows, and visual examples before any code.", detail: "Wireframes, UI mocks, copy direction", Icon: PenTool, tone: "bg-standout/10 text-standout" },
  { title: "Build", description: "Production-ready websites and stores with analytics, SEO and payment wiring.", detail: "Astro, Shopify, Next.js, Stripe", Icon: Code2, tone: "bg-accent/10 text-accent" },
  { title: "Automate", description: "n8n flows and AI assistants that handle the repetitive parts after launch.", detail: "n8n, OpenAI, integrations, monitoring", Icon: Rocket, tone: "bg-standout-2-10 text-standout" },
]

const toolkit = ["Shopify", "WooCommerce", "Astro", "Next.js", "Tailwind", "TypeScript", "Stripe", "Klaviyo", "Calendly", "Cal.com", "n8n", "OpenAI", "Anthropic", "Notion", "Airtable", "Google Sheets", "Slack", "HubSpot", "Pipedrive", "PostgreSQL", "Resend", "Twilio"]
const TOOLKIT_TONE = ["border-primary bg-primary/10 text-primary", "border-standout bg-standout/10 text-standout", "border-accent bg-accent/10 text-accent", "border-standout-2 bg-standout-2-10 text-standout-2"]

const galleryShots = [
  { title: "Golf tee-time booking", category: "Booking", description: "Member rates, deposit-on-book, weather-aware availability.", image: "/modern-saas-dashboard-with-dark-blue-and-orange-ge.jpg" },
  { title: "Premium product page", category: "Ecommerce", description: "Lookbook imagery, reviews, trust signals, fast checkout.", image: "/placeholder-ks40r.png" },
  { title: "Booking admin view", category: "Booking", description: "All bookings, statuses, and payments at a glance for staff.", image: "/placeholder-49g40.png" },
  { title: "Automation flow in n8n", category: "Automation", description: "Real workflow visible — triggers, AI step, branching, alerts.", image: "/placeholder-95zgk.png" },
]

const testimonials = [
  { name: "Lisa Patel", role: "Owner, CargoLine Spa", quote: "Our new booking page took the phone calls down to almost zero. Customers love being able to pick a treatment and stylist in 30 seconds.", outcome: "Online bookings now 78% of total revenue", avatar: "/professional-woman-portrait.png" },
  { name: "Andre Miller", role: "Founder, Northbeam Apparel", quote: "The Shopify rebuild repositioned the brand and turned the homepage into a sales engine. Subscriptions are now our biggest channel.", outcome: "Conversion up 2.4× and AOV up 18% in the first quarter", avatar: "/professional-man-portrait.png" },
  { name: "Rachel Gomez", role: "Director, Brevity Yoga", quote: "The automations they built handle every booking confirmation, reminder and renewal email. I genuinely don't think about it anymore.", outcome: "No-shows down 40% and pass renewals up 22%", avatar: "/professional-woman-portrait.png" },
]
---

<Layout title="Work — Studio Duo | Booking pages, ecommerce stores, automations" description="Selected work across booking pages, ecommerce stores, automation flows and AI tools — with the outcomes they produced.">
  <div class="min-h-screen bg-background">
    <Navigation />

    <main>
      <section class="relative overflow-hidden bg-section-white py-24 sm:py-32 text-section-white-foreground">
        <div class="absolute inset-0">
          <div class="absolute inset-0 bg-[radial-gradient(circle_at_top,_rgba(255,255,255,0.18),_transparent_70%)]"></div>
          <div class="absolute -bottom-24 left-1/2 h-80 w-[36rem] -translate-x-1/2 rounded-full bg-primary/20 blur-3xl"></div>
        </div>
        <div class="relative z-10 mx-auto max-w-7xl px-6 sm:px-8 lg:px-12">
          <Badge variant="secondary" class="mb-6 inline-flex items-center gap-2 bg-standout/20 text-standout border border-standout/30">
            <Sparkles className="h-4 w-4" /> Bookings • Ecommerce • Automation • AI
          </Badge>
          <h1 class="text-balance text-4xl font-bold leading-tight sm:text-5xl lg:text-6xl">
            Booking pages, ecommerce stores and automations — built to drive bookings, sales and time saved.
          </h1>
          <p class="mt-6 max-w-3xl text-lg text-muted-foreground sm:text-xl leading-relaxed">
            Every project below pairs design with a measurable outcome. Filter by what you're after — appointments, products, automations or AI assistants.
          </p>
          <div class="mt-10 flex flex-wrap gap-4">
            <a href="/contact" class="inline-flex items-center gap-2 h-10 px-8 rounded-md font-medium bg-standout text-white hover:bg-standout/90 shadow-lg">
              Start a project <ArrowRight className="h-5 w-5" />
            </a>
          </div>

          <div class="mt-16 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
            {
              heroStats.map(stat => (
                <div class="card-universal border border-border bg-card/50 backdrop-blur hover:shadow-lg transition-all rounded-xl py-6">
                  <div class="flex items-start gap-4 px-6">
                    <div class={`flex h-11 w-11 items-center justify-center rounded-full ${stat.tone}`}>
                      <stat.Icon className="h-5 w-5" />
                    </div>
                    <div>
                      <p class="text-sm uppercase tracking-wider text-muted-foreground">{stat.label}</p>
                      <p class="mt-2 text-3xl font-bold text-foreground">{stat.value}</p>
                    </div>
                  </div>
                </div>
              ))
            }
          </div>
        </div>
      </section>

      <section class="border-b border-border bg-section-muted py-20 sm:py-24">
        <div class="mx-auto max-w-7xl px-6 sm:px-8 lg:px-12">
          <div class="grid gap-12 lg:grid-cols-2 lg:items-center">
            <div class="space-y-8">
              <div class="space-y-4">
                <Badge variant="secondary" class="bg-standout/20 text-standout border border-standout/30">Showreel</Badge>
                <h2 class="text-3xl font-bold text-foreground sm:text-4xl">
                  Booking, ecommerce and automation — <span class="text-primary">in motion</span>
                </h2>
                <p class="max-w-xl text-base text-muted-foreground leading-relaxed">
                  Watch the actual flows we ship — booking funnels, checkout pages and live n8n automations — so you know exactly what shows up in production.
                </p>
              </div>
              <div class="grid gap-4 sm:grid-cols-2">
                {
                  showreelHighlights.map(item => (
                    <div class="card-universal border border-border bg-card/80 backdrop-blur hover:shadow-md transition-all rounded-xl py-6">
                      <div class="flex gap-4 px-5">
                        <div class={`flex h-12 w-12 items-center justify-center rounded-full ${item.tone}`}>
                          <item.Icon className="h-5 w-5" />
                        </div>
                        <div>
                          <p class="text-sm font-semibold text-foreground">{item.title}</p>
                          <p class="mt-1 text-sm text-muted-foreground">{item.description}</p>
                        </div>
                      </div>
                    </div>
                  ))
                }
              </div>
              <a href="/contact?demo=showreel" class="inline-flex items-center gap-2 h-10 px-6 rounded-md font-medium bg-standout text-white hover:bg-standout/90 shadow-lg">
                Request the private reel
              </a>
            </div>
            <div class="relative">
              <div class="relative overflow-hidden rounded-3xl border border-border bg-card shadow-xl">
                <video class="h-full w-full object-cover opacity-80" autoplay loop muted playsinline preload="none" poster="/modern-saas-dashboard-with-dark-blue-and-orange-ge.jpg">
                  <source src="/background-video.mp4" type="video/mp4" />
                </video>
                <div class="absolute inset-0 bg-gradient-to-tr from-black/50 via-black/20 to-transparent pointer-events-none z-0"></div>
                <div class="absolute top-6 right-6 z-10">
                  <button type="button" data-open-reel class="group inline-flex items-center gap-2 rounded-2xl bg-white/20 px-4 py-2 text-sm font-medium text-white backdrop-blur transition hover:bg-white hover:text-foreground dark:hover:text-gray-900">
                    <span class="flex h-8 w-8 items-center justify-center rounded-full bg-white text-foreground dark:text-gray-900">
                      <Play className="h-3 w-3" />
                    </span>
                    Watch reel
                  </button>
                </div>
                <div class="absolute bottom-6 left-6 right-6">
                  <div class="flex items-center gap-3 text-sm uppercase tracking-wider text-white/80 mb-3">
                    <div class="flex h-10 w-10 items-center justify-center rounded-full bg-white/20 text-white">
                      <Film className="h-4 w-4" />
                    </div>
                    In motion
                  </div>
                  <p class="text-xl font-semibold text-white">
                    Automations with safeguards, fast UIs, and clear paths to action on every surface.
                  </p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="bg-section-white py-20 sm:py-24">
        <div class="mx-auto max-w-7xl px-6 sm:px-8 lg:px-12">
          <div class="flex flex-wrap items-end justify-between gap-6 mb-12">
            <div>
              <Badge variant="secondary" class="bg-standout/20 text-standout border border-standout/30">Spotlight builds</Badge>
              <h2 class="mt-4 text-3xl font-bold text-foreground sm:text-4xl">
                Bookings, stores and automations — built for real businesses
              </h2>
              <p class="mt-3 max-w-2xl text-base text-muted-foreground leading-relaxed">
                Each build pairs automation, web, and internal tooling so teams see value quickly without juggling multiple vendors.
              </p>
            </div>
            <a href="/contact?request=build-walkthrough" class="inline-flex items-center gap-2 h-10 px-6 rounded-md font-medium text-base border-2 border-primary text-primary hover:bg-primary/10 bg-transparent">
              Book a tailored walkthrough
            </a>
          </div>
        </div>
        <SpotlightCarousel client:visible projects={spotlightProjects} />
      </section>

      <section class="border-b border-border bg-section-muted py-20 sm:py-24">
        <div class="mx-auto max-w-7xl px-6 sm:px-8 lg:px-12">
          <div class="flex flex-wrap items-center justify-between gap-6">
            <div>
              <Badge variant="secondary" class="bg-standout/20 text-standout border border-standout/30">Project library</Badge>
              <h2 class="mt-4 text-3xl font-bold text-foreground sm:text-4xl">
                Featured <span class="text-primary">outcomes</span> across bookings, ecommerce, automation and AI
              </h2>
              <p class="mt-3 max-w-2xl text-base text-muted-foreground leading-relaxed">
                Filter by the type of build you need. Every project includes discovery, build, analytics, and safeguards so you get production-ready outcomes.
              </p>
            </div>
          </div>
        </div>
        <ShowcaseCarousel client:visible projects={projects} categories={categories} />
      </section>

      <section class="bg-section-white py-20 sm:py-24">
        <div class="mx-auto max-w-7xl px-6 sm:px-8 lg:px-12">
          <div class="text-center">
            <Badge variant="secondary" class="mx-auto mb-6 bg-standout/20 text-standout border border-standout/30">Areas of focus</Badge>
            <h2 class="text-3xl font-bold text-foreground sm:text-4xl">
              Three focused areas: <span class="text-primary">bookings, ecommerce, and automation + AI</span>
            </h2>
            <p class="mt-4 max-w-3xl mx-auto text-base text-muted-foreground leading-relaxed">
              We join as a hands-on partner — mapping the workflows, designing the experience, and shipping the code so your team moves faster without extra headcount.
            </p>
          </div>
          <div class="mt-14 grid gap-8 md:grid-cols-3">
            {
              focusAreas.map(a => (
                <div class="card-universal h-full border border-border bg-card/80 backdrop-blur hover:shadow-lg transition-all rounded-xl py-6">
                  <div class="px-6 grid auto-rows-min grid-rows-[auto_auto] items-start gap-1.5 space-y-4">
                    <div class={`flex h-12 w-12 items-center justify-center rounded-full ${a.tone}`}>
                      <a.Icon className="h-6 w-6" />
                    </div>
                    <div class="text-xl text-foreground leading-none font-semibold">{a.title}</div>
                    <div class="text-base text-muted-foreground leading-relaxed">{a.description}</div>
                  </div>
                  <div class="px-6 space-y-3">
                    {a.points.map(p => (
                      <div class="flex items-start gap-3 text-sm text-muted-foreground">
                        <CheckCircle2 className="mt-0.5 h-4 w-4 text-primary flex-shrink-0" />
                        <span>{p}</span>
                      </div>
                    ))}
                  </div>
                </div>
              ))
            }
          </div>
        </div>
      </section>

      <section class="bg-section-muted py-20 sm:py-24">
        <div class="mx-auto max-w-7xl px-6 sm:px-8 lg:px-12">
          <div class="grid gap-10 lg:grid-cols-2">
            <div class="card-universal border border-border bg-card/80 backdrop-blur shadow-lg hover:shadow-xl transition-all rounded-xl py-6">
              <div class="px-6 space-y-3">
                <Badge variant="secondary" class="w-fit bg-standout/20 text-standout border border-standout/30">Process</Badge>
                <div class="text-2xl text-foreground leading-none font-semibold">
                  From <span class="text-primary">audit</span> to live automations and web launches
                </div>
                <div class="text-base text-muted-foreground leading-relaxed">
                  Clear milestones, shared notes, and weekly demos so you always know what shipped and what is next.
                </div>
              </div>
              <div class="px-6 space-y-6 mt-6">
                {
                  processSteps.map((step, i) => (
                    <div class="flex gap-4">
                      <div class={`flex h-12 w-12 items-center justify-center rounded-full font-semibold flex-shrink-0 ${step.tone}`}>
                        {String(i + 1).padStart(2, "0")}
                      </div>
                      <div class="space-y-2">
                        <div class="flex items-center gap-2">
                          <step.Icon className="h-5 w-5 text-primary" />
                          <h3 class="text-lg font-semibold text-foreground">{step.title}</h3>
                        </div>
                        <p class="text-sm text-muted-foreground leading-relaxed">{step.description}</p>
                        <p class="text-xs uppercase tracking-wider text-primary">{step.detail}</p>
                      </div>
                    </div>
                  ))
                }
              </div>
            </div>

            <div class="card-universal border border-border bg-card/80 backdrop-blur shadow-lg hover:shadow-xl transition-all rounded-xl py-6">
              <div class="px-6 space-y-3">
                <Badge variant="secondary" class="w-fit bg-standout/20 text-standout border border-standout/30">Toolkit</Badge>
                <div class="text-2xl text-foreground leading-none font-semibold">
                  Tools I <span class="text-primary">reach for</span> often
                </div>
                <div class="text-base text-muted-foreground leading-relaxed">
                  A flexible stack that covers automation, web, and system builds with maintainable handoffs.
                </div>
              </div>
              <div class="px-6 mt-6">
                <div class="flex flex-wrap gap-3">
                  {toolkit.map((item, i) => (
                    <span class={`rounded-full border px-4 py-1 text-sm font-medium transition-colors ${TOOLKIT_TONE[i % TOOLKIT_TONE.length]}`}>{item}</span>
                  ))}
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="border-t border-border bg-section-white py-20 sm:py-24">
        <div class="mx-auto max-w-7xl px-6 sm:px-8 lg:px-12">
          <div class="flex flex-wrap items-end justify-between gap-6">
            <div>
              <Badge variant="secondary" class="bg-standout/20 text-standout border border-standout/30">Visual gallery</Badge>
              <h2 class="mt-4 text-3xl font-bold text-foreground sm:text-4xl">
                Screens from <span class="text-primary">recent booking pages</span>, stores, and automation builds
              </h2>
              <p class="mt-3 max-w-2xl text-base text-muted-foreground leading-relaxed">
                A quick look at the interfaces, dashboards, and flows clients use to run their day-to-day.
              </p>
            </div>
            <a href="/contact?request=portfolio-deck" class="inline-flex items-center gap-2 h-10 px-6 rounded-md font-medium text-base border-2 border-primary text-primary hover:bg-primary/10 bg-transparent">
              Request full deck
            </a>
          </div>
          <div class="mt-14 grid gap-6 lg:grid-cols-3">
            {
              galleryShots.map((shot, i) => (
                <div class={`group relative overflow-hidden rounded-3xl border border-border bg-muted hover:shadow-xl transition-all ${i === 0 ? "lg:row-span-2" : ""}`}>
                  <img src={shot.image} alt={shot.title} loading="lazy" class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105" />
                  <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent transition-opacity duration-700 group-hover:opacity-95"></div>
                  <div class="absolute bottom-6 left-6 right-6 text-white">
                    <p class="text-xs uppercase tracking-wider text-white/60">{shot.category}</p>
                    <p class="mt-2 text-xl font-semibold leading-tight">{shot.title}</p>
                    <p class="mt-3 text-sm text-white/80 leading-relaxed">{shot.description}</p>
                  </div>
                </div>
              ))
            }
          </div>
        </div>
      </section>

      <section class="bg-section-muted py-20 sm:py-24">
        <div class="mx-auto max-w-7xl px-6 sm:px-8 lg:px-12">
          <div class="text-center">
            <Badge variant="secondary" class="mx-auto mb-6 bg-standout/20 text-standout border border-standout/30">Client reflections</Badge>
            <h2 class="text-3xl font-bold text-foreground sm:text-4xl">
              Businesses pick us when <span class="text-primary">outcomes</span> matter more than headcount
            </h2>
            <p class="mt-4 max-w-3xl mx-auto text-base text-muted-foreground leading-relaxed">
              Highlights from leaders who needed automation, web, and internal tools shipped by one accountable partner.
            </p>
          </div>
          <div class="mt-14 grid gap-8 md:grid-cols-2 lg:grid-cols-3">
            {
              testimonials.map(t => (
                <div class="card-universal border border-border bg-card/80 backdrop-blur shadow-lg hover:shadow-xl transition-all rounded-xl py-6">
                  <div class="space-y-6 p-6">
                    <div class="flex items-center gap-4">
                      <img src={t.avatar} alt={t.name} loading="lazy" class="h-12 w-12 rounded-full border border-primary/30 object-cover" />
                      <div>
                        <p class="font-semibold text-foreground">{t.name}</p>
                        <p class="text-sm text-muted-foreground">{t.role}</p>
                      </div>
                    </div>
                    <p class="text-base leading-relaxed text-foreground">“{t.quote}”</p>
                    <div class="flex items-center gap-2 text-sm font-medium text-primary">
                      <CheckCircle2 className="h-4 w-4" />
                      <span>{t.outcome}</span>
                    </div>
                  </div>
                </div>
              ))
            }
          </div>
        </div>
      </section>

      <section class="relative overflow-hidden bg-section-primary py-20 sm:py-24 text-section-primary-foreground">
        <div class="absolute inset-0">
          <div class="absolute -top-32 left-1/2 h-72 w-72 -translate-x-1/2 rounded-full bg-white/10 blur-3xl"></div>
          <div class="absolute -bottom-40 right-0 h-80 w-80 rounded-full bg-standout/30 blur-3xl"></div>
        </div>
        <div class="relative z-10 mx-auto max-w-4xl px-6 text-center">
          <Badge variant="secondary" class="mx-auto mb-6 bg-white/20 text-white border border-white/30">Let’s collaborate</Badge>
          <h2 class="text-3xl font-bold sm:text-5xl">
            Ready to take more bookings, sell more products or kill more admin?
          </h2>
          <p class="mt-5 text-lg text-section-primary-foreground/90 leading-relaxed">
            Share the workflows, pages, or tools that need to run better. We'll map the plan, build it, and launch it with instrumentation so you see the impact fast.
          </p>
          <div class="mt-8 flex flex-wrap justify-center gap-4">
            <a href="/contact" class="inline-flex items-center gap-2 h-10 px-8 rounded-md font-medium bg-white text-foreground hover:bg-white/90 dark:text-gray-900 shadow-lg">Plan my build</a>
            <a href="/contact" class="inline-flex items-center gap-2 h-10 px-8 rounded-md font-medium border border-white/30 bg-transparent text-white hover:bg-white/10">
              Get a tailored plan <ArrowRight className="h-5 w-5" />
            </a>
          </div>
        </div>
      </section>
    </main>

    <CornerVideoPlayer client:visible />
    <Footer />
  </div>
</Layout>

