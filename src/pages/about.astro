---
import Layout from "@/layouts/Layout.astro"
import Navigation from "@/components/Navigation.astro"
import Footer from "@/components/Footer.astro"

const team = [
  {
    name: "Joel Shore",
    role: "Engineering · Co-founder",
    bio: "Joel builds the websites, stores and automations. Background in commerce, internal tools and the quiet plumbing that makes a small team feel like a large one.",
    strengths: ["TypeScript", "n8n", "Shopify", "Stripe"],
    avatar: "JS",
  },
  {
    name: "Ella Wynter",
    role: "Design · Co-founder",
    bio: "Ella shapes the brand voice, page structure and the editorial feel of everything we ship. Cares deeply about typography, restraint and a clear sense of place.",
    strengths: ["Brand", "Editorial", "Design systems"],
    avatar: "EW",
  },
]

const values = [
  { k: "01", t: "Two people, every project.", b: "Same two faces from kickoff to launch. No sub-contracting, no account managers, no handoffs that lose the plot." },
  { k: "02", t: "Build for the operator, not the deck.", b: "What you'll be running on Tuesday morning matters more than what looks good in a launch screenshot. Restraint over rinse-cycle." },
  { k: "03", t: "Make the boring bits invisible.", b: "If we built it well, the automations run quietly, the analytics are honest, and you spend your time on the work only you can do." },
  { k: "04", t: "Ship, then refine.", b: "We launch in weeks not quarters. Then we tune against real numbers — what your customers actually do, not what the focus group said." },
]

const process = [
  { n: "01", t: "Plan",     b: "A short call, then a written brief that names the outcome, the constraints, and the success metric." },
  { n: "02", t: "Design",   b: "Wireframes and visual designs for every page or screen — agreed before any code is written." },
  { n: "03", t: "Build",    b: "Production-ready code, payments, SEO and analytics wired in. Demos every 3–5 days." },
  { n: "04", t: "Automate", b: "n8n flows and AI assistants for the parts that should happen on their own. Documented and yours to edit." },
]

const stats = [
  { v: "150+", l: "Projects shipped" },
  { v: "98%",  l: "Client retention" },
  { v: "5 yrs", l: "Building this duo" },
  { v: "24 h", l: "Average reply time" },
]
---

<Layout
  title="About — Studio Duo"
  description="Two people. Websites, ecommerce stores, booking pages and quiet automations. Manchester, UK."
>
  <Navigation />

  <section class="page-head">
    <div class="wrap">
      <div class="crumb">
        <a href="/">Studio Duo</a>
        <span class="sep">/</span>
        <span>About</span>
      </div>
      <div class="page-head-grid">
        <div data-reveal>
          <span class="eyebrow">About the studio</span>
          <h1>Two people. Sites, stores &amp; <em>quiet machines.</em></h1>
          <p class="lede">A small studio in Manchester. We design and build websites, ecommerce stores, booking pages and the automations behind them — and we work on every project from kickoff to launch ourselves.</p>
          <div class="svc-actions" style="margin-top:28px">
            <a class="btn btn-primary" href="/contact">Book a 20-min intro
              <svg class="ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
            </a>
            <a class="btn btn-ghost" href="/work">See recent work</a>
          </div>
        </div>
        <div class="page-head-meta" data-reveal>
          <div><div class="k">Founded</div><div class="v">2021 · Manchester</div></div>
          <div><div class="k">Team</div><div class="v">Two co-founders</div></div>
          <div><div class="k">Focus</div><div class="v">Web · Commerce · Automation</div></div>
          <div><div class="k">Available</div><div class="v">Q3 2026 · 1 slot</div></div>
        </div>
      </div>
    </div>
  </section>

  <!-- TEAM -->
  <section class="section" id="team">
    <div class="wrap">
      <div class="sec-head left" data-reveal>
        <span class="eyebrow">The team</span>
        <h2 class="sec-title">The two people who'll <em>actually build it.</em></h2>
        <p class="sec-blurb">No account managers, no contractors. You'll be talking to the same two people on day one and on launch day.</p>
      </div>

      <div class="team-grid">
        {team.map(m => (
          <article class="team-card" data-reveal>
            <div class="team-head">
              <span class="team-avatar">{m.avatar}</span>
              <div>
                <h3>{m.name}</h3>
                <p class="team-role">{m.role}</p>
              </div>
            </div>
            <p class="team-bio">{m.bio}</p>
            <ul class="team-tags">
              {m.strengths.map(s => <li>{s}</li>)}
            </ul>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- VALUES -->
  <section class="section" id="values" style="background:var(--bg-2);border-top:1px solid var(--hair);border-bottom:1px solid var(--hair)">
    <div class="wrap">
      <div class="sec-head left" data-reveal>
        <span class="eyebrow">How we work</span>
        <h2 class="sec-title">Four habits we <em>refuse to drop.</em></h2>
      </div>

      <div class="values-grid">
        {values.map(v => (
          <article class="value-card" data-reveal>
            <span class="value-k">{v.k}</span>
            <h3>{v.t}</h3>
            <p>{v.b}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- PROCESS -->
  <section class="section" id="process">
    <div class="wrap">
      <div class="sec-head left" data-reveal>
        <span class="eyebrow">Process</span>
        <h2 class="sec-title">Four steps, same for <em>every project.</em></h2>
        <p class="sec-blurb">Whether it's a single landing page or a full ecommerce build with n8n automations behind it, the path looks the same.</p>
      </div>

      <ol class="process-grid">
        {process.map(p => (
          <li class="process-step" data-reveal>
            <span class="process-n">{p.n}</span>
            <h3>{p.t}</h3>
            <p>{p.b}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- STATS -->
  <section class="section tight" id="stats" style="background:var(--ink);color:var(--surface)">
    <div class="wrap">
      <div class="stats-grid" data-reveal>
        {stats.map(s => (
          <div class="stat">
            <div class="stat-v">{s.v}</div>
            <div class="stat-l">{s.l}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta">
    <div class="cta-inner">
      <span class="eyebrow">Start a project</span>
      <h2>Tell us what you want <em>to ship.</em></h2>
      <p>A short form, a 20-minute call, or a direct email. Whichever feels right. 24-hour reply, no pitch.</p>
      <div class="cta-actions">
        <a class="btn btn-primary" href="/contact">
          Start a project
          <svg class="ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </a>
        <a class="btn btn-ghost" href="/work">See recent work</a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<style is:global>
  /* Team cards ---------------------------------------------- */
  .team-grid { display: grid; grid-template-columns: 1fr; gap: 20px; }
  @media (min-width: 800px) { .team-grid { grid-template-columns: 1fr 1fr; gap: 28px; } }
  .team-card {
    background: var(--surface); border: 1px solid var(--hair); border-radius: 18px;
    padding: 32px; display: grid; gap: 18px; align-content: start;
    transition: transform .25s ease, box-shadow .25s ease, border-color .25s ease;
  }
  .team-card:hover { transform: translateY(-2px); box-shadow: var(--shadow-md); border-color: color-mix(in oklab, var(--ink) 18%, transparent); }
  .team-head { display: grid; grid-template-columns: 64px 1fr; gap: 18px; align-items: center; }
  .team-avatar {
    width: 64px; height: 64px; border-radius: 99px;
    background: linear-gradient(135deg, var(--brand-soft), var(--peach));
    display: grid; place-items: center;
    font-family: "Gloock", serif; font-size: 22px; letter-spacing: -.02em; color: var(--ink);
  }
  .team-card h3 { font-family: "Gloock", serif; font-weight: 400; font-size: 24px; letter-spacing: -.03em; margin: 0; line-height: 1.1; }
  .team-role { font-family: "Fragment Mono", monospace; font-size: 11px; letter-spacing: .14em; text-transform: uppercase; color: var(--muted-ink); margin: 4px 0 0; }
  .team-bio { color: var(--muted-ink); font-size: 15px; line-height: 1.6; margin: 0; }
  .team-tags { list-style: none; margin: 0; padding: 0; display: flex; flex-wrap: wrap; gap: 6px; }
  .team-tags li {
    font-family: "Fragment Mono", monospace; font-size: 10.5px;
    letter-spacing: .04em; color: var(--muted-ink);
    border: 1px solid var(--hair); border-radius: 999px;
    padding: 4px 10px;
  }

  /* Values cards -------------------------------------------- */
  .values-grid { display: grid; grid-template-columns: 1fr; gap: 14px; }
  @media (min-width: 700px)  { .values-grid { grid-template-columns: 1fr 1fr; gap: 18px; } }
  @media (min-width: 1100px) { .values-grid { grid-template-columns: repeat(4, 1fr); } }
  .value-card {
    background: var(--surface); border: 1px solid var(--hair); border-radius: 16px;
    padding: 26px; display: grid; gap: 12px; align-content: start;
    transition: transform .25s ease, box-shadow .25s ease;
  }
  .value-card:hover { transform: translateY(-2px); box-shadow: var(--shadow-sm); }
  .value-k { font-family: "Fragment Mono", monospace; font-size: 11px; letter-spacing: .16em; color: var(--brand); }
  .value-card h3 { font-family: "Gloock", serif; font-weight: 400; font-size: 20px; letter-spacing: -.025em; margin: 0; line-height: 1.15; text-wrap: balance; }
  .value-card p { color: var(--muted-ink); font-size: 14px; line-height: 1.55; margin: 0; }

  /* Process steps ------------------------------------------- */
  .process-grid { list-style: none; padding: 0; margin: 0; display: grid; grid-template-columns: 1fr; gap: 18px; }
  @media (min-width: 700px)  { .process-grid { grid-template-columns: 1fr 1fr; } }
  @media (min-width: 1100px) { .process-grid { grid-template-columns: repeat(4, 1fr); } }
  .process-step {
    background: var(--surface); border: 1px solid var(--hair); border-radius: 16px;
    padding: 28px; display: grid; gap: 10px; align-content: start;
    position: relative;
  }
  .process-n {
    font-family: "Gloock", serif; font-size: 44px; letter-spacing: -.04em;
    color: var(--brand); line-height: 1;
  }
  .process-step h3 { font-family: "Gloock", serif; font-weight: 400; font-size: 22px; letter-spacing: -.03em; margin: 0; }
  .process-step p { color: var(--muted-ink); font-size: 14px; line-height: 1.55; margin: 0; }

  /* Stats band ---------------------------------------------- */
  .stats-grid {
    display: grid; grid-template-columns: 1fr 1fr; gap: 40px 32px;
    padding: 12px 0; text-align: left;
  }
  @media (min-width: 800px) { .stats-grid { grid-template-columns: repeat(4, 1fr); } }
  .stat { display: grid; gap: 6px; }
  .stat-v { font-family: "Gloock", serif; font-weight: 400; font-size: clamp(40px, 4.4vw, 56px); letter-spacing: -.045em; line-height: 1; }
  .stat-l { font-family: "Fragment Mono", monospace; font-size: 11px; letter-spacing: .14em; text-transform: uppercase; color: rgba(255,255,255,.6); }
</style>
