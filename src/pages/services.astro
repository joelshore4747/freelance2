---
import { ShoppingBag, CalendarCheck, Workflow, Sparkles, CheckCircle, ArrowRight, Clock, Award, TrendingUp, Users, Target, Headphones, Calendar } from "lucide-react"
import Layout from "@/layouts/Layout.astro"
import Navigation from "@/components/Navigation.astro"
import Footer from "@/components/Footer.astro"
import Badge from "@/components/ui/Badge.astro"
import GetStartedButton from "@/components/GetStartedButton.astro"

const heroPoints = [
  "Premium websites tailored to your brand and audience",
  "Ecommerce stores built for clarity, trust and checkout speed",
  "Booking pages that turn enquiries into confirmed customers",
  "n8n + AI automations that remove repetitive admin",
]

const heroMetrics = [
  { Icon: Target, number: "150+", label: "Projects Delivered", description: "Across web, ecommerce, automation" },
  { Icon: Users, number: "98%", label: "Client Satisfaction", description: "Happy clients rate" },
  { Icon: Calendar, number: "5+", label: "Years Experience", description: "In web + automation" },
  { Icon: Headphones, number: "24/7", label: "Support", description: "Always reachable" },
]

const offers = [
  {
    id: "ecommerce",
    Icon: ShoppingBag,
    badge: "Ecommerce",
    title: "Ecommerce Stores",
    subtitle: "Premium ecommerce websites built to sell products clearly, quickly and professionally.",
    price: "from £3,500",
    forWhom: "Clothing, beauty, hair, supplement, food & drink, handmade and small online brands.",
    includes: [
      "Shopify or WooCommerce setup",
      "Homepage, collection & product pages",
      "Cart and checkout polish",
      "Payment + shipping setup",
      "Reviews and trust sections",
      "Email capture",
      "Analytics + basic SEO",
    ],
    examples: ["Hair & beauty store", "Fitness supplement store", "Fashion brand storefront", "Local artisan shop"],
  },
  {
    id: "booking",
    Icon: CalendarCheck,
    badge: "Bookings",
    title: "Booking Websites",
    subtitle: "Clean booking pages for service businesses that want customers to book without calling, messaging or waiting for a reply.",
    price: "from £2,500",
    forWhom: "Barbers, salons, spas, yoga studios, gyms, golf clubs, restaurants, clinics, coaches, activity venues.",
    includes: [
      "Booking page design",
      "Appointment, class or reservation flow",
      "Deposit / payment setup",
      "Calendar integration",
      "Confirmation + reminder emails",
      "Enquiry forms",
      "Admin view for bookings",
    ],
    examples: ["Golf tee-time booking", "Yoga class booking", "Spa treatment booking", "Restaurant reservations"],
  },
  {
    id: "automation",
    Icon: Workflow,
    badge: "Automation",
    title: "Workflow Automation",
    subtitle: "Automations that connect your apps, reduce repetitive admin and keep your business moving without manual copy-paste work.",
    price: "from £1,200",
    forWhom: "Businesses taking lots of enquiries, ecommerce stores, agencies, trades, clinics, appointment-based businesses.",
    includes: [
      "Workflow audit",
      "n8n automation build",
      "App integrations (Shopify, Stripe, Calendly, Slack, Sheets, Notion, Airtable, CRMs)",
      "Test runs against real data",
      "Documentation",
      "30 days of support",
    ],
    examples: ["Form → CRM → Slack alert", "Booking → confirmation → calendar event", "Order → fulfilment alert → customer email", "Abandoned enquiry chaser"],
    cta: { label: "See automation examples", href: "/automation" },
  },
  {
    id: "ai",
    Icon: Sparkles,
    badge: "AI",
    title: "AI Business Tools",
    subtitle: "Practical AI tools that help businesses answer questions, process enquiries, create content and save time.",
    price: "from £900",
    forWhom: "Ecommerce brands, service businesses, agencies, consultants — anyone with repeated customer questions or messy admin.",
    includes: [
      "AI website chatbot / FAQ assistant",
      "AI enquiry summariser",
      "AI quote / proposal helper",
      "AI email reply drafts",
      "AI lead qualification",
      "AI product description generator",
      "AI internal knowledge assistant",
    ],
    examples: ["Chatbot trained on your FAQs", "Lead qualification + summary", "Bulk product description generator", "AI-drafted customer replies"],
  },
]

const reasons = [
  { Icon: Award, title: "Focused Scope", description: "Four services we ship every week — not a long list of side hustles." },
  { Icon: Clock, title: "Fast Delivery", description: "Most projects launch in 4–8 weeks. Automations often in days." },
  { Icon: TrendingUp, title: "Outcome-Led", description: "Bookings, sales and time saved are the metrics we design for." },
  { Icon: Users, title: "Direct Access", description: "You work with the team building it — no account managers." },
]

const stages = [
  { step: "01", title: "Plan", description: "Audit the offer, current tools and the workflows you want to fix or build. Agree what success looks like." },
  { step: "02", title: "Design", description: "Wireframes and visual designs for every page or screen before any code." },
  { step: "03", title: "Build", description: "Production-ready websites and stores with payments, SEO and analytics wired in." },
  { step: "04", title: "Automate", description: "n8n flows and AI assistants that handle the repetitive parts after launch." },
]
---

<Layout
  title="Services — Studio Duo | Ecommerce, Bookings, Automation, AI"
  description="Ecommerce stores, booking websites, n8n workflow automation and practical AI business tools. Four focused services that work together."
>
  <div class="min-h-screen bg-background text-foreground">
    <Navigation />

    <section class="py-20 lg:py-32 bg-section-white text-section-white-foreground">
      <div class="max-w-7xl mx-auto px-6 sm:px-8 lg:px-12">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <div>
            <Badge class="mb-6 font-serif border-2 border-standout/30 bg-standout/20 text-standout font-semibold">
              Websites • Ecommerce • Automation • AI
            </Badge>
            <h1 class="text-4xl md:text-6xl font-bold text-foreground font-sans mb-6 text-balance">
              Everything You Need to <span class="text-standout">Sell, Book & Automate</span>
            </h1>
            <p class="text-xl text-muted-foreground font-serif mb-8 text-pretty">
              Four focused services that help businesses get more bookings, more sales and less manual admin.
            </p>
            <div class="space-y-4 mb-8">
              {
                heroPoints.map(point => (
                  <div class="flex items-start gap-3">
                    <CheckCircle className="h-5 w-5 text-primary flex-shrink-0 mt-0.5" />
                    <span class="text-muted-foreground font-serif">{point}</span>
                  </div>
                ))
              }
            </div>
            <GetStartedButton size="lg" class="font-serif font-semibold" />
          </div>

          <div class="grid grid-cols-2 gap-6">
            {
              heroMetrics.map(m => (
                <div class="card-universal bg-card/80 text-card-foreground rounded-xl border border-border/80 shadow-md py-6 hover:shadow-xl transition-all duration-300">
                  <div class="text-center px-6">
                    <div class="w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center text-primary mb-4 mx-auto">
                      <m.Icon className="h-8 w-8" />
                    </div>
                    <div class="text-3xl font-bold text-foreground font-sans mb-1">{m.number}</div>
                    <div class="text-sm font-semibold text-foreground font-sans mb-1">{m.label}</div>
                    <div class="text-xs text-muted-foreground font-serif">{m.description}</div>
                  </div>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    {
      offers.map((o, i) => (
        <section id={o.id} class={`py-20 lg:py-28 ${i % 2 === 0 ? "bg-section-muted" : "bg-section-white"}`}>
          <div class="max-w-7xl mx-auto px-6 sm:px-8 lg:px-12">
            <div class="grid lg:grid-cols-5 gap-12 items-start">
              <div class="lg:col-span-2">
                <Badge class="mb-4 font-serif border-2 border-standout/30 bg-standout/20 text-standout font-semibold">{o.badge}</Badge>
                <div class="flex items-center gap-4 mb-6">
                  <div class="w-14 h-14 rounded-2xl bg-primary/10 flex items-center justify-center text-primary">
                    <o.Icon className="h-7 w-7" />
                  </div>
                  <h2 class="text-3xl md:text-4xl font-bold text-foreground font-sans">{o.title}</h2>
                </div>
                <p class="text-lg text-muted-foreground font-serif mb-6 text-pretty leading-relaxed">{o.subtitle}</p>
                <div class="rounded-2xl border border-border/70 bg-card/60 backdrop-blur p-5 mb-6">
                  <p class="text-xs uppercase tracking-wider text-muted-foreground font-semibold mb-1">Starts</p>
                  <p class="text-2xl font-bold text-foreground font-sans">{o.price}</p>
                </div>
                <p class="text-sm text-muted-foreground font-serif">
                  <span class="font-semibold text-foreground">Best for:</span> {o.forWhom}
                </p>
                <div class="flex flex-wrap gap-3 mt-6">
                  <GetStartedButton size="lg" class="font-serif font-semibold" />
                  {o.cta && (
                    <a href={o.cta.href} class="inline-flex items-center gap-2 h-10 px-6 rounded-md text-base font-serif font-semibold border bg-transparent hover:bg-accent hover:text-accent-foreground transition-colors">
                      {o.cta.label} <ArrowRight className="h-4 w-4" />
                    </a>
                  )}
                </div>
              </div>

              <div class="lg:col-span-3 grid md:grid-cols-2 gap-6">
                <div class="card-universal bg-card text-card-foreground rounded-xl border border-border/80 shadow-sm py-6">
                  <div class="px-6 mb-4">
                    <h3 class="font-semibold text-foreground font-sans">What's included</h3>
                  </div>
                  <ul class="px-6 space-y-2">
                    {o.includes.map(f => (
                      <li class="flex items-center gap-2 text-muted-foreground font-serif text-sm">
                        <CheckCircle className="h-4 w-4 text-primary flex-shrink-0" />
                        {f}
                      </li>
                    ))}
                  </ul>
                </div>
                <div class="card-universal bg-card text-card-foreground rounded-xl border border-border/80 shadow-sm py-6">
                  <div class="px-6 mb-4">
                    <h3 class="font-semibold text-foreground font-sans">Example use cases</h3>
                  </div>
                  <ul class="px-6 space-y-2">
                    {o.examples.map(f => (
                      <li class="flex items-center gap-2 text-muted-foreground font-serif text-sm">
                        <span class="w-1.5 h-1.5 bg-standout rounded-full flex-shrink-0"></span>
                        {f}
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
            </div>
          </div>
        </section>
      ))
    }

    <section class="py-20 lg:py-32 bg-section-white">
      <div class="max-w-7xl mx-auto px-6 sm:px-8 lg:px-12">
        <div class="text-center mb-16">
          <h2 class="text-3xl md:text-5xl font-bold text-foreground font-sans mb-6 text-balance">Why Choose Us</h2>
          <p class="text-xl text-muted-foreground font-serif max-w-2xl mx-auto text-pretty">
            A small team that owns strategy, design, build and automation so nothing gets lost between handoffs.
          </p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
          {
            reasons.map(r => (
              <div class="card-universal text-center bg-card/80 text-card-foreground border border-border/80 p-6 rounded-xl shadow-sm hover:shadow-lg transition-all">
                <div class="w-16 h-16 bg-primary/10 rounded-2xl flex items-center justify-center text-primary mb-4 mx-auto">
                  <r.Icon className="h-8 w-8" />
                </div>
                <h3 class="text-xl font-bold text-foreground font-sans mb-3">{r.title}</h3>
                <p class="text-muted-foreground font-serif text-pretty">{r.description}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <section class="py-20 lg:py-32 bg-section-muted">
      <div class="max-w-7xl mx-auto px-6 sm:px-8 lg:px-12">
        <div class="text-center mb-16">
          <h2 class="text-3xl md:text-5xl font-bold text-foreground font-sans mb-6 text-balance">How We Work</h2>
          <p class="text-xl text-muted-foreground font-serif max-w-2xl mx-auto text-pretty">
            Plan, design, build, automate. Same process whether you need a store, a booking page or a workflow.
          </p>
        </div>
        <div class="relative">
          <div class="hidden lg:block absolute top-8 left-0 right-0 h-0.5 bg-border"></div>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
            {
              stages.map(p => (
                <div class="text-center relative">
                  <div class="w-16 h-16 bg-primary rounded-2xl flex items-center justify-center text-primary-foreground font-bold text-xl font-sans mb-4 mx-auto relative z-10 shadow-lg">
                    {p.step}
                  </div>
                  <h3 class="text-xl font-bold text-foreground font-sans mb-3">{p.title}</h3>
                  <p class="text-muted-foreground font-serif text-pretty">{p.description}</p>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    <section class="py-20 lg:py-32 bg-section-white">
      <div class="max-w-4xl mx-auto px-6 sm:px-8 lg:px-12 text-center">
        <h2 class="text-3xl md:text-5xl font-bold text-foreground font-sans mb-6 text-balance">Ready to ship something?</h2>
        <p class="text-xl text-muted-foreground font-serif mb-8 text-pretty">
          Tell us what you want to build — store, booking page, automation or AI tool — and we'll come back with a plan.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <GetStartedButton size="lg" class="font-serif font-semibold" />
          <a href="/work" class="inline-flex items-center justify-center gap-2 h-10 px-6 rounded-md text-base font-serif font-semibold border bg-transparent hover:bg-accent hover:text-accent-foreground transition-colors">
            View Our Work <ArrowRight className="ml-2 h-4 w-4" />
          </a>
        </div>
      </div>
    </section>

    <Footer />

    <GetStartedButton variant="sticky" />
  </div>
</Layout>
