---
import Layout from "@/layouts/Layout.astro"
import Navigation from "@/components/Navigation.astro"
import Footer from "@/components/Footer.astro"

const jumps = [
  { href: "#ecommerce",  k: "01 · Ecommerce",  v: "Stores that sell",       from: "From £3,500" },
  { href: "#booking",    k: "02 · Booking",    v: "Calendar-driven sites",  from: "From £2,500" },
  { href: "#automation", k: "03 · Automation", v: "n8n workflows",          from: "From £1,200" },
  { href: "#ai",         k: "04 · AI tools",   v: "Practical assistants",   from: "From £900"  },
]

const addons = [
  { tag: "Care · monthly", title: "Maintenance plan",  body: "Updates, content edits, bug fixes & automation tuning. Cancel anytime.",        price: "£250/mo", tone: "" },
  { tag: "SEO · once",     title: "SEO sprint",         body: "2-week audit, structured-data fixes, content brief & technical wins.",         price: "£1,200",  tone: "" },
  { tag: "Email · once",   title: "Klaviyo / lifecycle",body: "Welcome, browse-abandon, post-purchase & win-back flows in your voice.",       price: "£1,800",  tone: "" },
  { tag: "Custom",          title: "Something else?",    body: "Internal tools, landing pages, custom integrations. Tell us what you need.",    price: null,      tone: "dark" },
]
---

<Layout
  title="Services — Studio Duo"
  description="Ecommerce, booking, workflow automation and practical AI — four focused services that compound."
>
  <Navigation />

  <section class="page-head">
    <div class="wrap">
      <div class="crumb">
        <a href="/">Studio Duo</a>
        <span class="sep">/</span>
        <span>Services</span>
      </div>
      <div class="page-head-grid">
        <div data-reveal>
          <span class="eyebrow">Services</span>
          <h1>Four focused services that <em>compound.</em></h1>
          <p class="lede">A small, opinionated stack: a beautiful website, a booking page that converts, the workflows that run behind it and the AI tools that handle the boring bits.</p>
        </div>
        <div class="page-head-meta" data-reveal>
          <div><div class="k">Delivery</div><div class="v">2–8 weeks</div></div>
          <div><div class="k">Team</div><div class="v">2 designers, 1 engineer</div></div>
          <div><div class="k">Locations</div><div class="v">UK · Remote</div></div>
          <div><div class="k">Available</div><div class="v">Q3 2026 (4 slots)</div></div>
        </div>
      </div>

      <div class="svc-jump">
        {jumps.map(j => (
          <a href={j.href}>
            <span class="k">{j.k}</span>
            <span class="v">{j.v}</span>
            <span class="from">{j.from}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ECOMMERCE -->
  <section class="svc-block brand" id="ecommerce">
    <div class="wrap">
      <div class="svc-grid">
        <div class="svc-head" data-reveal>
          <span class="eyebrow">01 · Ecommerce</span>
          <h2>Stores that look <em>handpicked,</em> not built.</h2>
          <p class="lede">Shopify &amp; WooCommerce builds with checkout polish, reviews, email capture and the trust details that move conversion. Editorial product pages your customers actually finish reading.</p>
          <h5 class="includes-head">What's included</h5>
          <ul class="svc-includes">
            <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12l5 5 9-9"/></svg><span>Editorial product pages, collection pages, lookbook + journal modules</span></li>
            <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12l5 5 9-9"/></svg><span>Shopify or WooCommerce setup, theme &amp; payment provider</span></li>
            <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12l5 5 9-9"/></svg><span>Reviews, email capture, abandoned-cart flow &amp; trust details</span></li>
            <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12l5 5 9-9"/></svg><span>SEO, analytics, accessibility &amp; mobile-first build</span></li>
            <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12l5 5 9-9"/></svg><span>30-day post-launch tuning &amp; a Loom walkthrough so you can update yourself</span></li>
          </ul>
          <div class="svc-meta">
            <div><div class="k">From</div><div class="v">£3,500</div></div>
            <div><div class="k">Delivery</div><div class="v">4–8 weeks</div></div>
            <div><div class="k">Platforms</div><div class="v">Shopify · WooCommerce</div></div>
            <div><div class="k">Good for</div><div class="v">Product brands, subscription</div></div>
          </div>
          <div class="svc-actions">
            <a class="btn btn-primary" href="/contact?service=ecommerce">Start an ecommerce project
              <svg class="ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
            </a>
            <a class="btn btn-ghost" href="/case-study">See case study</a>
          </div>
        </div>

        <div class="svc-vis" data-reveal>
          <div class="mock-store">
            <div class="bar">
              <span class="d"></span><span class="d"></span><span class="d"></span>
              <span style="margin-left:14px">roma-supplements.co</span>
              <span class="u">cart · 2</span>
            </div>
            <div class="hero">
              <div>
                <div class="label">Daily essentials, beautifully made.</div>
                <div class="sub">New collection · Shop now</div>
              </div>
            </div>
            <div class="grid">
              <div class="pr"><div class="ph"></div><div class="n">Morning protein</div><div class="p">£32 · subscribe</div></div>
              <div class="pr"><div class="ph"></div><div class="n">Magnesium</div><div class="p">£18 · subscribe</div></div>
              <div class="pr"><div class="ph"></div><div class="n">Omega-3</div><div class="p">£24 · subscribe</div></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- BOOKING -->
  <section class="svc-block stone" id="booking">
    <div class="wrap">
      <div class="svc-grid reverse">
        <div class="svc-vis" data-reveal>
          <div class="mock-book">
            <div class="top">
              <div class="h">June 2026</div>
              <div class="arrows"><span>‹</span><span>›</span></div>
            </div>
            <div class="grid">
              <div class="cal">
                <div class="dow">M</div><div class="dow">T</div><div class="dow">W</div><div class="dow">T</div><div class="dow">F</div><div class="dow">S</div><div class="dow">S</div>
                <div class="d empty"></div><div class="d empty"></div><div class="d">1</div><div class="d dot">2</div><div class="d">3</div><div class="d dot">4</div><div class="d">5</div>
                <div class="d">6</div><div class="d dot">7</div><div class="d">8</div><div class="d sel">9</div><div class="d dot">10</div><div class="d">11</div><div class="d">12</div>
                <div class="d dot">13</div><div class="d">14</div><div class="d">15</div><div class="d">16</div><div class="d dot">17</div><div class="d">18</div><div class="d dot">19</div>
                <div class="d">20</div><div class="d">21</div><div class="d dot">22</div><div class="d">23</div><div class="d">24</div><div class="d">25</div><div class="d dot">26</div>
              </div>
              <div class="slots">
                <div class="hh">Tue 9 Jun</div>
                <div class="slot"><span>09:30</span><span class="t">45 min</span></div>
                <div class="slot pick"><span>11:00</span><span class="t">45 min</span></div>
                <div class="slot"><span>14:30</span><span class="t">45 min</span></div>
                <div class="slot"><span>16:00</span><span class="t">45 min</span></div>
              </div>
            </div>
          </div>
        </div>

        <div class="svc-head" data-reveal>
          <span class="eyebrow">02 · Booking</span>
          <h2>Pages people actually <em>finish.</em></h2>
          <p class="lede">Salon, spa, gym, golf club or studio — calendar-driven booking with deposits, reminders, member rates and the kind of UX that turns a casual visit into a confirmed appointment.</p>
          <h5 class="includes-head">What's included</h5>
          <ul class="svc-includes">
            <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12l5 5 9-9"/></svg><span>Custom booking flow with services, durations, staff &amp; rooms</span></li>
            <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12l5 5 9-9"/></svg><span>Stripe deposits, member rates &amp; gift cards</span></li>
            <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12l5 5 9-9"/></svg><span>Email &amp; SMS reminders, calendar sync (Google/Outlook)</span></li>
            <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12l5 5 9-9"/></svg><span>Capacity, waitlists &amp; cancellation rules</span></li>
            <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12l5 5 9-9"/></svg><span>Admin dashboard your team can actually use</span></li>
          </ul>
          <div class="svc-meta">
            <div><div class="k">From</div><div class="v">£2,500</div></div>
            <div><div class="k">Delivery</div><div class="v">2–4 weeks</div></div>
            <div><div class="k">Platforms</div><div class="v">Custom + Cal.com / Calendly</div></div>
            <div><div class="k">Good for</div><div class="v">Salons, studios, clinics</div></div>
          </div>
          <div class="svc-actions">
            <a class="btn btn-primary" href="/contact?service=booking">Start a booking project
              <svg class="ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
            </a>
            <a class="btn btn-ghost" href="/case-study">See case study</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- AUTOMATION -->
  <section class="svc-block dark" id="automation">
    <div class="wrap">
      <div class="svc-grid">
        <div class="svc-head" data-reveal>
          <span class="eyebrow">03 · Automation · n8n</span>
          <h2>Workflows that do the admin at <em>3am.</em></h2>
          <p class="lede">Built in n8n so they're visible and editable. Forms enrich themselves, bookings confirm themselves, follow-ups go out on their own. The quiet machine your business has been pretending to be.</p>
          <h5 class="includes-head">What's included</h5>
          <ul class="svc-includes">
            <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12l5 5 9-9"/></svg><span>Audit of your current admin tasks &amp; bottleneck mapping</span></li>
            <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12l5 5 9-9"/></svg><span>n8n flows you own &amp; can edit yourself (no proprietary lock-in)</span></li>
            <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12l5 5 9-9"/></svg><span>Integrations with CRM, Slack, email, calendar, Notion, Airtable</span></li>
            <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12l5 5 9-9"/></svg><span>Error monitoring, retry logic &amp; a clear audit trail</span></li>
            <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12l5 5 9-9"/></svg><span>30-day tuning + a Loom walkthrough of every flow</span></li>
          </ul>
          <div class="svc-meta">
            <div><div class="k">From</div><div class="v">£1,200</div></div>
            <div><div class="k">Delivery</div><div class="v">2–3 weeks</div></div>
            <div><div class="k">Platform</div><div class="v">n8n (self-host or cloud)</div></div>
            <div><div class="k">Good for</div><div class="v">Service ops, agencies, B2B</div></div>
          </div>
          <div class="svc-actions">
            <a class="btn btn-primary svc-btn-brand" href="/contact?service=automation">Start an automation project
              <svg class="ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
            </a>
            <a class="btn btn-ghost svc-btn-translucent" href="/case-study">See case study</a>
          </div>
        </div>

        <div class="svc-vis" data-reveal>
          <div class="mock-auto">
            <div class="row">
              <div class="node"><div class="k">Trigger</div><div class="v">New form submission</div></div>
              <span class="arr">→</span>
              <div class="node"><div class="k">Step 1</div><div class="v">Enrich w/ Clearbit</div></div>
            </div>
            <div class="row indent-1">
              <div class="node brand"><div class="k">Step 2 · AI</div><div class="v">Summarise &amp; classify</div></div>
              <span class="arr">→</span>
              <div class="node"><div class="k">Step 3</div><div class="v">Push to HubSpot</div></div>
            </div>
            <div class="row indent-2">
              <div class="node"><div class="k">Step 4</div><div class="v">Slack alert · #leads</div></div>
              <span class="arr">→</span>
              <div class="node"><div class="k">Done</div><div class="v">Audit log written</div></div>
            </div>
            <div class="stats">
              <div><span class="vv">1.4s</span><span class="ll">Avg run</span></div>
              <div><span class="vv">99.6%</span><span class="ll">Success</span></div>
              <div><span class="vv">412</span><span class="ll">Last 30d</span></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- AI -->
  <section class="svc-block peach" id="ai">
    <div class="wrap">
      <div class="svc-grid reverse">
        <div class="svc-vis tall" data-reveal>
          <div class="mock-ai">
            <div class="bub a">Hi! I'm Studio Duo's support assistant — what can I help you with today?</div>
            <div class="bub u">Where's my order? Placed it Tuesday morning.</div>
            <div class="bub a">Found it — order #4821 shipped yesterday with DHL. Tracking: <b>JD0014123823</b>. Expected Friday between 9am–1pm. Anything else?</div>
            <div class="bub u">Can I add a second item to it?</div>
            <div class="bub a"><span class="typing"><span></span><span></span><span></span></span></div>
            <div class="input">
              <span>Ask anything…</span>
              <span class="b">Send</span>
            </div>
          </div>
        </div>

        <div class="svc-head" data-reveal>
          <span class="eyebrow">04 · AI tools</span>
          <h2>Practical AI that <em>earns its keep.</em></h2>
          <p class="lede">No demos that look great and break in production. Scoped chatbots trained on your FAQs, enquiry summarisers, AI email drafters and product description generators — the boring bits, quietly handled.</p>
          <h5 class="includes-head">What's included</h5>
          <ul class="svc-includes">
            <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12l5 5 9-9"/></svg><span>Support chatbot trained on your FAQs, docs &amp; product catalogue</span></li>
            <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12l5 5 9-9"/></svg><span>Enquiry summariser + smart email reply drafts</span></li>
            <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12l5 5 9-9"/></svg><span>Product description &amp; content generators</span></li>
            <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12l5 5 9-9"/></svg><span>Guardrails, escalation rules &amp; an honest "I don't know" mode</span></li>
            <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12l5 5 9-9"/></svg><span>Usage dashboard &amp; monthly review of accuracy</span></li>
          </ul>
          <div class="svc-meta">
            <div><div class="k">From</div><div class="v">£900</div></div>
            <div><div class="k">Delivery</div><div class="v">1–3 weeks</div></div>
            <div><div class="k">Models</div><div class="v">OpenAI · Claude · self-host</div></div>
            <div><div class="k">Good for</div><div class="v">Support-heavy businesses</div></div>
          </div>
          <div class="svc-actions">
            <a class="btn btn-primary" href="/contact?service=ai">Start an AI project
              <svg class="ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
            </a>
            <a class="btn btn-ghost" href="/case-study">See case study</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ADD-ONS -->
  <section class="section addons-section">
    <div class="wrap">
      <div class="sec-head left" data-reveal>
        <span class="eyebrow">Add-ons &amp; care plans</span>
        <h2 class="sec-title">Extras for after <em>launch.</em></h2>
      </div>
      <div class="addon-grid">
        {addons.map(a => (
          <div class={`addon ${a.tone}`}>
            <span class="mono addon-tag">{a.tag}</span>
            <h3>{a.title}</h3>
            <p>{a.body}</p>
            {a.price
              ? <div class="addon-price">From <b>{a.price}</b></div>
              : <a class="link-arrow addon-link" href="/contact">Get in touch
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
                </a>
            }
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="cta">
    <div class="cta-inner">
      <span class="eyebrow">Start a project</span>
      <h2>Pick a service. <em>Or all four.</em></h2>
      <p>Tell us what you want to ship and we'll come back inside 24 hours with a plan and a price.</p>
      <div class="cta-actions">
        <a class="btn btn-primary" href="/contact">
          Start a project
          <svg class="ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </a>
        <a class="btn btn-ghost" href="/pricing">See pricing</a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<style is:global>
  /* jump strip ------------------------------------------------ */
  .svc-jump { display: grid; grid-template-columns: 1fr; gap: 12px; margin: 40px 0 0; }
  @media (min-width: 800px) { .svc-jump { grid-template-columns: repeat(4, 1fr); } }
  .svc-jump a {
    padding: 18px 20px; border-radius: 14px; border: 1px solid var(--hair);
    background: var(--surface); display: grid; gap: 4px; text-decoration: none; color: inherit;
    transition: transform .2s ease, border-color .2s ease, box-shadow .2s ease;
  }
  .svc-jump a:hover { transform: translateY(-2px); border-color: var(--ink); box-shadow: var(--shadow-md); }
  .svc-jump .k { font-family: "Fragment Mono", monospace; font-size: 10px; letter-spacing: .16em; text-transform: uppercase; color: var(--brand); }
  .svc-jump .v { font-size: 18px; font-weight: 500; letter-spacing: -.01em; }
  .svc-jump .from { font-family: "Fragment Mono", monospace; font-size: 11px; color: var(--muted-dim); margin-top: 4px; }

  /* SERVICE block --------------------------------------------- */
  .svc-block { padding: 110px 0; border-top: 1px solid var(--hair); position: relative; }
  .svc-block.dark { background: var(--ink); color: var(--surface); }
  .svc-block.dark .eyebrow { color: color-mix(in oklab, var(--mint) 85%, white); }
  .svc-block.stone { background: var(--bg-2); }
  .svc-block.brand { background: linear-gradient(180deg, #F4EBDD, var(--bg)); }
  .svc-block.peach { background: linear-gradient(180deg, #FFF0E5, var(--bg)); }

  .svc-grid { display: grid; grid-template-columns: 1fr; gap: 48px; align-items: start; }
  @media (min-width: 900px) { .svc-grid { grid-template-columns: 1fr 1.1fr; gap: 80px; } }
  .svc-grid.reverse > :first-child { order: 2; }
  @media (min-width: 900px) { .svc-grid.reverse > :first-child { order: initial; } }

  .svc-head h2 { font-family: "Gloock", serif; font-weight: 400; font-size: clamp(40px, 5vw, 64px); line-height: .96; letter-spacing: -.055em; margin: 14px 0 18px; max-width: 14ch; text-wrap: balance; }
  .svc-head h2 em { font-style: italic; font-weight: 400; background: linear-gradient(105deg, var(--brand), var(--brand-2), var(--peach)); -webkit-background-clip: text; background-clip: text; color: transparent; }
  .svc-block.dark .svc-head h2 em { background: linear-gradient(105deg, #E8B698, #BDA69B, #ECD8CC); -webkit-background-clip: text; background-clip: text; color: transparent; }
  .svc-head .lede { color: var(--muted-ink); font-size: 17px; line-height: 1.6; max-width: 48ch; margin: 0 0 32px; }
  .svc-block.dark .svc-head .lede { color: rgba(255, 255, 255, .72); }
  .includes-head { font-family: "Fragment Mono", monospace; font-size: 11px; letter-spacing: .16em; text-transform: uppercase; color: var(--ink); margin: 0 0 18px; }
  .svc-block.dark .includes-head { color: var(--surface); }

  .svc-meta { display: grid; grid-template-columns: 1fr 1fr; gap: 14px 32px; padding-top: 20px; border-top: 1px solid var(--hair); margin-top: 32px; }
  .svc-block.dark .svc-meta { border-top-color: rgba(255, 255, 255, .14); }
  .svc-meta .k { font-family: "Fragment Mono", monospace; font-size: 10px; letter-spacing: .16em; text-transform: uppercase; color: var(--muted-dim); }
  .svc-meta .v { font-size: 14px; margin-top: 4px; }
  .svc-block.dark .svc-meta .v { color: var(--surface); }

  .svc-includes { list-style: none; padding: 0; margin: 0; display: grid; gap: 10px; }
  .svc-includes li { display: grid; grid-template-columns: 22px 1fr; gap: 12px; align-items: start; font-size: 15px; line-height: 1.5; }
  .svc-includes li svg { width: 18px; height: 18px; color: var(--brand); margin-top: 2px; }
  .svc-block.dark .svc-includes li svg { color: #E8B698; }

  .svc-actions { margin-top: 32px; display: flex; gap: 12px; flex-wrap: wrap; }
  .svc-btn-brand { background: var(--brand); }
  .svc-btn-translucent { background: rgba(255,255,255,.06); border-color: rgba(255,255,255,.18); color: var(--surface); }
  .svc-btn-translucent:hover { background: rgba(255,255,255,.1); border-color: rgba(255,255,255,.3); }

  /* svc visual ------------------------------------------------ */
  .svc-vis { position: relative; border-radius: 24px; overflow: hidden; border: 1px solid var(--hair); min-height: 480px; background: var(--surface); box-shadow: var(--shadow-md); }
  .svc-vis.tall { min-height: 520px; }
  .svc-block.dark .svc-vis { border-color: rgba(255, 255, 255, .14); background: #181612; box-shadow: 0 30px 60px -30px rgba(0,0,0,.5); }

  /* Storefront mockup ----------------------------------------- */
  .mock-store { display: grid; grid-template-rows: 36px 220px 1fr; height: 100%; }
