---
import { Workflow, ArrowRight, Mail, Calendar, ShoppingBag, Database, FileText, Sparkles } from "lucide-react"
import Layout from "@/layouts/Layout.astro"
import Navigation from "@/components/Navigation.astro"
import Footer from "@/components/Footer.astro"
import Badge from "@/components/ui/Badge.astro"
import GetStartedButton from "@/components/GetStartedButton.astro"

const examples = [
  {
    Icon: Mail,
    title: "Website form → CRM + Slack alert",
    description: "New enquiry comes in. We enrich it with company info, summarise it with AI, push it to your CRM and ping the right person on Slack — in under a minute.",
    apps: ["Webhook", "Clearbit", "OpenAI", "HubSpot", "Slack"],
  },
  {
    Icon: Calendar,
    title: "Booking → confirmation → calendar → reminder",
    description: "A customer books online. They get an instant confirmation email, the event lands on the right calendar, and a reminder fires the day before with directions.",
    apps: ["Calendly", "Google Calendar", "Gmail", "Twilio"],
  },
  {
    Icon: ShoppingBag,
    title: "Ecommerce order → fulfilment + receipt",
    description: "Order placed. Stock decremented, fulfilment alerted with shipping label data, customer gets a branded receipt, and a happy-path follow-up lands a week later.",
    apps: ["Shopify", "ShipStation", "Klaviyo", "Sheets"],
  },
  {
    Icon: FileText,
    title: "Abandoned enquiry chaser",
    description: "Someone fills half the form and bounces. 24 hours later they get a soft nudge with a one-click way to finish. 72 hours later it escalates to a human.",
    apps: ["Webhook", "Postgres", "Resend", "Slack"],
  },
  {
    Icon: Sparkles,
    title: "AI-drafted customer replies",
    description: "Support email comes in. AI drafts a reply using your existing knowledge base and prior tickets. A human approves or edits before it sends.",
    apps: ["Gmail", "OpenAI", "Notion", "Approval gate"],
  },
  {
    Icon: Database,
    title: "Daily ops report",
    description: "Every morning at 8am, pull sales, bookings, support tickets and ad spend from your tools, format them into a short summary, and email it to the team.",
    apps: ["Stripe", "Shopify", "Linear", "Sheets", "Gmail"],
  },
]

const connectableTools = [
  "Shopify", "WooCommerce", "Stripe", "PayPal", "Klaviyo", "Mailchimp",
  "Calendly", "Cal.com", "Google Calendar", "Outlook",
  "Gmail", "Outlook Mail", "Resend", "Postmark",
  "HubSpot", "Pipedrive", "Salesforce", "Notion CRM",
  "Notion", "Airtable", "Google Sheets", "Excel",
  "Slack", "Discord", "Teams", "Telegram",
  "OpenAI", "Anthropic", "ElevenLabs", "Whisper",
  "Postgres", "MySQL", "Webhooks", "REST APIs",
]

const why = [
  { title: "Less manual copy-paste", description: "If you do the same thing more than twice a week, it can be automated. Most of our clients reclaim 5–15 hours a week." },
  { title: "Fewer dropped leads", description: "Speed-to-reply matters. Automating the first response and routing rules cuts lead loss dramatically." },
  { title: "Cleaner data", description: "One source of truth. No more 'is the spreadsheet or the CRM right?' Workflows keep everything in sync." },
  { title: "AI where it earns its keep", description: "Summaries, drafts, classification, qualification — AI does the boring pre-work so a human spends time on the decision, not the typing." },
]

const process = [
  { step: "01", title: "Audit", description: "Walk through your current tools and the manual steps eating the most time. Identify the 2–3 flows with the biggest payoff." },
  { step: "02", title: "Map", description: "Sketch the workflow end-to-end — triggers, conditions, approvals, fallbacks. You sign it off before we build." },
  { step: "03", title: "Build", description: "Implemented in n8n with version control, secrets management, and test runs against your real data." },
  { step: "04", title: "Hand over", description: "Documentation, runbooks, and access. We stay on retainer for tuning if you want — otherwise it just runs." },
]
---

<Layout
  title="Workflow Automation — Studio Duo | n8n + AI"
  description="Stop manually copying leads, sending repeated emails and updating spreadsheets. n8n + AI automations that keep your business running while you sleep."
>
  <div class="min-h-screen bg-background text-foreground">
    <Navigation />

    <section class="page-head">
      <div class="wrap">
        <div class="crumb">
          <a href="/">Studio Duo</a>
          <span class="sep">/</span>
          <a href="/services">Services</a>
          <span class="sep">/</span>
          <span>Workflow automation</span>
        </div>
        <div class="page-head-grid">
          <div data-reveal>
            <span class="eyebrow">Workflow automation · n8n + AI</span>
            <h1>Stop copying leads, repeating emails &amp; <em>updating spreadsheets.</em></h1>
            <p class="lede">We build automations in n8n that connect your tools, route work between people, and let AI do the repetitive parts. You see every step. You own every flow.</p>
            <div class="svc-actions" style="margin-top:28px">
              <a class="btn btn-primary" href="/contact?service=automation">Audit my workflow
                <svg class="ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
              <a class="btn btn-ghost" href="#examples">See examples</a>
            </div>
          </div>
          <div class="page-head-meta" data-reveal>
            <div><div class="k">From</div><div class="v">£1,200</div></div>
            <div><div class="k">Delivery</div><div class="v">2–3 weeks</div></div>
            <div><div class="k">Platform</div><div class="v">n8n · self-host or cloud</div></div>
            <div><div class="k">Good for</div><div class="v">Service ops, agencies, B2B</div></div>
          </div>
        </div>
      </div>
    </section>

    <section class="bg-section-muted py-20 sm:py-24">
      <div class="mx-auto max-w-7xl px-6 sm:px-8 lg:px-12">
        <div class="text-center mb-16">
          <Badge variant="secondary" class="mx-auto mb-6 bg-standout/20 text-standout border border-standout/30">Why automate</Badge>
          <h2 class="text-3xl font-bold text-foreground sm:text-4xl">
            Automation pays back the moment <span class="text-primary">a repeat task disappears</span>.
          </h2>
        </div>
        <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-4">
          {
            why.map(w => (
              <div class="card-universal h-full border border-border bg-card/80 backdrop-blur shadow-sm hover:shadow-lg transition-all rounded-xl py-6">
                <div class="px-6">
                  <h3 class="text-lg font-bold text-foreground mb-3 font-sans">{w.title}</h3>
                  <p class="text-sm text-muted-foreground font-serif leading-relaxed">{w.description}</p>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <section id="examples" class="bg-section-white py-20 sm:py-24">
      <div class="mx-auto max-w-7xl px-6 sm:px-8 lg:px-12">
        <div class="text-center mb-16">
          <Badge variant="secondary" class="mx-auto mb-6 bg-standout/20 text-standout border border-standout/30">Example automations</Badge>
          <h2 class="text-3xl font-bold text-foreground sm:text-4xl">
            Real flows we've shipped for <span class="text-primary">real businesses</span>
          </h2>
          <p class="mt-4 max-w-3xl mx-auto text-base text-muted-foreground leading-relaxed">
            These are just patterns. Yours will be different — but the building blocks are the same.
          </p>
        </div>
        <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
          {
            examples.map(e => (
              <div class="card-universal h-full border border-border bg-card/80 backdrop-blur shadow-md hover:shadow-xl transition-all rounded-xl py-6">
                <div class="px-6">
                  <div class="w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center text-primary mb-4">
                    <e.Icon className="h-6 w-6" />
                  </div>
                  <h3 class="text-lg font-bold text-foreground mb-2 font-sans">{e.title}</h3>
                  <p class="text-sm text-muted-foreground font-serif leading-relaxed mb-4">{e.description}</p>
                  <div class="flex flex-wrap gap-2">
                    {e.apps.map(a => (
                      <span class="tech-tag text-xs">{a}</span>
                    ))}
                  </div>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <section class="bg-section-muted py-20 sm:py-24">
      <div class="mx-auto max-w-7xl px-6 sm:px-8 lg:px-12">
        <div class="text-center mb-12">
          <Badge variant="secondary" class="mx-auto mb-6 bg-standout/20 text-standout border border-standout/30">Tools we connect</Badge>
          <h2 class="text-3xl font-bold text-foreground sm:text-4xl">
            If you use it, we can <span class="text-primary">probably wire it in</span>
          </h2>
          <p class="mt-4 max-w-3xl mx-auto text-base text-muted-foreground leading-relaxed">
            n8n connects to hundreds of services natively, plus anything with a webhook or REST API. Some of the ones we reach for most:
          </p>
        </div>
        <div class="flex flex-wrap justify-center gap-3 max-w-5xl mx-auto">
          {
            connectableTools.map(tool => (
              <span class="rounded-full border border-border bg-card/80 backdrop-blur px-4 py-1.5 text-sm font-medium text-foreground hover:border-standout hover:text-standout transition-colors">
                {tool}
              </span>
            ))
          }
        </div>
      </div>
    </section>

    <section class="bg-section-white py-20 sm:py-24">
      <div class="mx-auto max-w-7xl px-6 sm:px-8 lg:px-12">
        <div class="text-center mb-16">
          <Badge variant="secondary" class="mx-auto mb-6 bg-standout/20 text-standout border border-standout/30">How it works</Badge>
          <h2 class="text-3xl font-bold text-foreground sm:text-4xl">
            From <span class="text-primary">audit</span> to live workflow in days, not months
          </h2>
        </div>
        <div class="relative">
          <div class="hidden lg:block absolute top-10 left-0 right-0 h-1 bg-gradient-to-r from-gray-300 via-gray-400 to-gray-300 rounded-full"></div>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">
            {
              process.map(p => (
                <div class="text-center relative">
                  <div class="w-20 h-20 bg-gradient-to-br from-primary to-standout rounded-3xl flex items-center justify-center text-white mb-6 mx-auto relative z-10 shadow-2xl text-2xl font-bold">
                    {p.step}
                  </div>
                  <h3 class="text-xl font-bold text-foreground font-sans mb-4">{p.title}</h3>
                  <p class="text-muted-foreground font-serif text-pretty text-base leading-relaxed">{p.description}</p>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    <section class="relative overflow-hidden bg-section-primary py-20 sm:py-24 text-section-primary-foreground">
      <div class="absolute inset-0">
        <div class="absolute -top-32 left-1/2 h-72 w-72 -translate-x-1/2 rounded-full bg-white/10 blur-3xl"></div>
        <div class="absolute -bottom-40 right-0 h-80 w-80 rounded-full bg-standout/30 blur-3xl"></div>
      </div>
      <div class="relative z-10 mx-auto max-w-4xl px-6 text-center">
        <Badge variant="secondary" class="mx-auto mb-6 bg-white/20 text-white border border-white/30">Let's talk</Badge>
        <h2 class="text-3xl font-bold sm:text-5xl">Show us your current workflow.</h2>
        <p class="mt-5 text-lg text-section-primary-foreground/90 leading-relaxed">
          Send a quick description of what's manual today and we'll come back with what's automatable — usually within 48 hours.
        </p>
        <div class="mt-8 flex flex-wrap justify-center gap-4">
          <a href="/contact?service=automation" class="inline-flex items-center gap-2 h-10 px-8 rounded-md font-medium bg-card text-card-foreground hover:bg-card/90 shadow-lg">Audit my workflow</a>
          <a href="/services" class="inline-flex items-center gap-2 h-10 px-8 rounded-md font-medium border border-white/30 bg-transparent text-white hover:bg-white/10">
            All services <ArrowRight className="h-5 w-5" />
          </a>
        </div>
      </div>
    </section>

    <Footer />
  </div>
</Layout>
